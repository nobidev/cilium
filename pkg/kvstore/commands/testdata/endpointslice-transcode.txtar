kvstore/update -i json cilium/state/endpointslices/v1/cluster-a/default/backend endpointslice.json

# Check that EndpointSlices are not stored as JSON
kvstore/list -o plain --values-only cilium/state/endpointslices/v1 endpointslice.plain
! grep -q '^{' endpointslice.plain

# Test JSON transcording with explicit json output and auto
kvstore/list -o json cilium/state/endpointslices/v1 endpointslice.actual
cmp endpointslice.actual endpointslice.expected
kvstore/list cilium/state/endpointslices/v1 endpointslice.actual
cmp endpointslice.actual endpointslice.expected

-- endpointslice.expected --
# cilium/state/endpointslices/v1/cluster-a/default/backend
{
  "cluster": "cluster-a",
  "clusterID": 1,
  "namespace": "default",
  "name": "backend",
  "addressType": "IPv4",
  "endpoints": [
    {
      "addresses": [
        "10.0.0.1"
      ],
      "conditions": {
        "ready": true,
        "serving": true,
        "terminating": false
      }
    }
  ],
  "ports": [
    {
      "name": "http",
      "protocol": "TCP",
      "port": 80
    }
  ]
}
-- endpointslice.json --
