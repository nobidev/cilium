hive start

db/initialized

# Add initial k8s resources.
k8s/add node1.yaml ciliumnode1.yaml
k8s/add policy1.yaml
k8s/add ciliumendpoint1.yaml

# Wait and check for in memory state
db/show policy-config --columns ID,Endpoints,Generation,IsGateway,EgressIP,Groups policy-config
db/cmp policy-config policyconfig.expected.1

# Check that manager realizes expected bpf map state.
egressha/policy-maps-dump policymap.actual
* cmp policymap.actual policymap.expected.1

-- policyconfig.expected.1 --
ID        Endpoints       Generation   IsGateway   EgressIP    Groups
policy1   [10.244.3.91]   1            true        100.1.2.3   [active=[172.18.0.3],healthy=[172.18.0.3],byGateway=map[172.18.0.3:100.1.2.3]]
-- policymap.expected.1 --
source_ip=10.244.3.91 dest_cidr=0.0.0.0 egress_ip=100.1.2.3 gateway_ips=[172.18.0.3]
