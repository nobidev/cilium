#! --diagnostics-interval=100ms --diagnostics-export-file=$WORK/status.log

hive/start

# Check that metadata and diagnostics updates are being posted
* grep '"system_status":{.*"metadata".*diagnostics_simulated_failure' status.log
cat status.log
* grep '"system_status":{.*"status":.*"total_conditions":2' status.log
! grep '"system_status":{.*"status":.*failing_conditions' status.log

# Validate table
db/cmp diagnostics diagnostics.table

# Toggle the simulated failure
diagnostics/toggle-fail
db/cmp diagnostics diagnostics_fail.table

# Validate JSON output (for sysdump as part of statedb dump)
db/show diagnostics -f json -o diagnostics-actual.json
sed '"EvaluatedAt": .*' '"EvaluatedAt": <sanitized>,' diagnostics-actual.json
sed '"Avg.*' '<sanitized>' diagnostics-actual.json
sed '"P[59].*' '<sanitized>' diagnostics-actual.json
sed '"TotalCount": 0,' '"TotalCount": <zero>,' diagnostics-actual.json
sed '"TotalCount": \d+,' '"TotalCount": <not-zero>,' diagnostics-actual.json
sed '"FailedCount": 0,' '"FailedCount": <zero>,' diagnostics-actual.json
sed '"FailedCount": \d+,' '"FailedCount": <not-zero>,' diagnostics-actual.json
* cmp diagnostics-actual.json diagnostics.json

# Verify that a failing conditions is posted
* grep '"system_status":{.*"status":.*failing_conditions.*diagnostics_simulated_failure' status.log

###

-- diagnostics.table --
ID                              Failed  Latest                      LastFailure     Evaluator
diagnostics_evaluation_duration 0       Succeeded 0s ago: OK        <none>          diagnostics.(*internalConditions).checkEvaluationDuration
diagnostics_simulated_failure   0       Succeeded 0s ago: OK        <none>          diagnostics.(*internalConditions).checkSimulatedFailure

-- diagnostics_fail.table --
ID                              Latest                                              LastFailure
diagnostics_evaluation_duration Succeeded 0s ago: OK                                <none>
diagnostics_simulated_failure   Failed 0s ago (DEBUG): Simulated failure triggered  Failed 0s ago (DEBUG): Simulated failure triggered

