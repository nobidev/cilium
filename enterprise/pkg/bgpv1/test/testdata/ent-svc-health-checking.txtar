#! --test-peering-ips=fd00::aa:aa:aa:101,fd00::aa:aa:aa:102

# Tests service advertisements with health-checking for service backends.

# Start the hive
hive start

# Configure gobgp server
gobgp/add-server test --router-id=1.2.3.4 65001 fd00::aa:aa:aa:101 1790
gobgp/add-peer fd00::aa:aa:aa:102 65001

# Configure BGP on Cilium
k8s/add cilium-node.yaml bgp-node-config.yaml bgp-peer-config.yaml bgp-advertisement.yaml
* bgptest/sync-oss-resources

# Configure a service and endpoints
k8s/add service.yaml endpoints.yaml endpoints-ipv6.yaml
db/cmp frontends frontends.table

# Wait for peering to be established
gobgp/wait-state fd00::aa:aa:aa:102 ESTABLISHED

# Validate IPv4 service VIP is advertised
gobgp/routes -o routes.actual ipv4 unicast
* cmp gobgp-routes-ipv4.expected routes.actual

# Validate IPv6 service VIP is advertised
gobgp/routes -o routes.actual ipv6 unicast
* cmp gobgp-routes-ipv6.expected routes.actual


# Update service backend counts - 1 healthy backend for each frontend
bgptest/set-backend-health 172.16.1.1:80/TCP 1
bgptest/set-backend-health [fd00:aa:bb::1]:80/TCP 1

# Validate IPv4 service VIP is advertised
gobgp/routes -o routes.actual ipv4 unicast
* cmp gobgp-routes-ipv4.expected routes.actual

# Validate IPv6 service VIP is advertised
gobgp/routes -o routes.actual ipv6 unicast
* cmp gobgp-routes-ipv6.expected routes.actual

# Update service backend counts - no healthy backend for IPv4 frontend
bgptest/set-backend-health 172.16.1.1:80/TCP 0

# Validate IPv4 service VIP is withdrawn
gobgp/routes -o routes.actual ipv4 unicast
* cmp gobgp-routes-ipv4-empty.expected routes.actual

# Validate IPv6 service VIP is still advertised
gobgp/routes -o routes.actual ipv6 unicast
* cmp gobgp-routes-ipv6.expected routes.actual


# Update service to use advertise-threshold 3
k8s/update service-threshold-3.yaml

# Validate IPv4 service VIP is withdrawn
gobgp/routes -o routes.actual ipv4 unicast
* cmp gobgp-routes-ipv4-empty.expected routes.actual

# Validate IPv6 service VIP is withdrawn
gobgp/routes -o routes.actual ipv6 unicast
* cmp gobgp-routes-ipv6-empty.expected routes.actual

# Update service backend counts - 3 healthy backends for each frontend
bgptest/set-backend-health 172.16.1.1:80/TCP 3
bgptest/set-backend-health [fd00:aa:bb::1]:80/TCP 3

# Validate IPv4 service VIP is advertised
gobgp/routes -o routes.actual ipv4 unicast
* cmp gobgp-routes-ipv4.expected routes.actual

# Validate IPv6 service VIP is advertised
gobgp/routes -o routes.actual ipv6 unicast
* cmp gobgp-routes-ipv6.expected routes.actual

#####

-- frontends.table --
Address                        Type           ServiceName Status  Backends
10.96.50.104:80/TCP            ClusterIP      test/svc1   Done    10.244.1.1:80/TCP, 10.244.1.2:80/TCP, 10.244.1.3:80/TCP
172.16.1.1:80/TCP              LoadBalancer   test/svc1   Done    10.244.1.1:80/TCP, 10.244.1.2:80/TCP, 10.244.1.3:80/TCP
[2001:db8:fd00::7ebc]:80/TCP   ClusterIP      test/svc1   Done    [2001::1]:80/TCP, [2001::2]:80/TCP, [2001::3]:80/TCP
[fd00:aa:bb::1]:80/TCP         LoadBalancer   test/svc1   Done    [2001::1]:80/TCP, [2001::2]:80/TCP, [2001::3]:80/TCP

-- cilium-node.yaml --
apiVersion: cilium.io/v2
kind: CiliumNode
metadata:
  name: test-node
spec:
  addresses:
  - ip: fd00::aa:aa:aa:102
    type: InternalIP
  ipam:
    podCIDRs:
    - 10.244.0.0/24
    - fd00:11:22::/64

-- bgp-node-config.yaml --
apiVersion: isovalent.com/v1
kind: IsovalentBGPNodeConfig
metadata:
  name: test-node
spec:
  bgpInstances:
  - localASN: 65001
    routerID: 5.6.7.8
    name: tor
    peers:
    - name: gobgp-peer
      peerASN: 65001
      peerAddress: fd00::aa:aa:aa:101
      localAddress: fd00::aa:aa:aa:102
      peerConfigRef:
        name: gobgp-peer-config

-- bgp-peer-config.yaml --
apiVersion: isovalent.com/v1
kind: IsovalentBGPPeerConfig
metadata:
  name: gobgp-peer-config
spec:
  transport:
    peerPort: 1790
  timers:
    connectRetryTimeSeconds: 1
  families:
  - afi: ipv4
    safi: unicast
    advertisements:
      matchLabels:
        advertise: bgp
  - afi: ipv6
    safi: unicast
    advertisements:
      matchLabels:
        advertise: bgp

-- bgp-advertisement.yaml --
apiVersion: isovalent.com/v1
kind: IsovalentBGPAdvertisement
metadata:
  labels:
    advertise: bgp
  name: bgp-advertisements
spec:
  advertisements:
  - advertisementType: Service
    service:
      addresses:
      - LoadBalancerIP
    selector:
      matchExpressions:
        - { key: bgp, operator: In, values: [ advertise ] }

-- service.yaml --
apiVersion: v1
kind: Service
metadata:
  name: svc1
  namespace: test
  labels:
    bgp: advertise
  annotations:
    "service.cilium.io/health-check-probe-interval": "1s"
spec:
  type: LoadBalancer
  clusterIP: 10.96.50.104
  clusterIPs:
  - 10.96.50.104
  - 2001:db8:fd00::7ebc
  externalTrafficPolicy: Cluster
  internalTrafficPolicy: Cluster
  ipFamilies:
  - IPv4
  - IPv6
  ipFamilyPolicy: DualStack
  ports:
  - name: http
    port: 80
    protocol: TCP
    targetPort: 80
  selector:
    name: echo
  sessionAffinity: None
status:
  loadBalancer:
    ingress:
    - ip: 172.16.1.1
    - ip: fd00:aa:bb::1

-- service-threshold-3.yaml --
apiVersion: v1
kind: Service
metadata:
  name: svc1
  namespace: test
  labels:
    bgp: advertise
  annotations:
    "service.cilium.io/health-check-probe-interval": "1s"
    "service.cilium.io/health-check-bgp-advertise-threshold": "3"
spec:
  type: LoadBalancer
  clusterIP: 10.96.50.104
  clusterIPs:
  - 10.96.50.104
  - 2001:db8:fd00::7ebc
  externalTrafficPolicy: Cluster
  internalTrafficPolicy: Cluster
  ipFamilies:
  - IPv4
  - IPv6
  ipFamilyPolicy: DualStack
  ports:
  - name: http
    port: 80
    protocol: TCP
    targetPort: 80
  selector:
    name: echo
  sessionAffinity: None
status:
  loadBalancer:
    ingress:
    - ip: 172.16.1.1
    - ip: fd00:aa:bb::1

-- endpoints.yaml --
apiVersion: discovery.k8s.io/v1
kind: EndpointSlice
metadata:
  labels:
    kubernetes.io/service-name: svc1
  name: svc1-eps
  namespace: test
addressType: IPv4
endpoints:
- addresses:
  - 10.244.1.1
  - 10.244.1.2
  - 10.244.1.3
  conditions:
    ready: true
    serving: true
    terminating: false
  nodeName: test-node
ports:
- name: http
  port: 80
  protocol: TCP

-- endpoints-ipv6.yaml --
apiVersion: discovery.k8s.io/v1
kind: EndpointSlice
metadata:
  labels:
    kubernetes.io/service-name: svc1
  name: svc1-eps-ipv6
  namespace: test
addressType: IPv6
endpoints:
- addresses:
  - 2001::1
  - 2001::2
  - 2001::3
  conditions:
    ready: true
    serving: true
    terminating: false
  nodeName: test-node
ports:
- name: http
  port: 80
  protocol: TCP

