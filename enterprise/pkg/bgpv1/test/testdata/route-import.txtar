#! --test-peering-ips=10.100.100.1,fd00:10:100:100::1

hive start
db/initialized

# Configure gobgp servers
gobgp/add-server v4 --router-id=1.2.3.4 65001 10.100.100.1 1790
gobgp/add-peer -s v4 10.100.100.1 65001
gobgp/add-server v6 --router-id=1.2.3.4 65001 fd00:10:100:100::1 1790
gobgp/add-peer -s v6 fd00:10:100:100::1 65001

# Configure BGP on Cilium
k8s/add cilium-node.yaml bgp-node-config.yaml bgp-peer-config-v4.yaml bgp-peer-config-v6.yaml bgp-policy.yaml
bgptest/sync-oss-resources

# Check that the policy is applied as expected
bgp/route-policies-extended -o bgp-policy.actual
* cmp bgp-policy.expected bgp-policy.actual

# Wait for peering to be established
gobgp/wait-state -s v4 10.100.100.1 ESTABLISHED
gobgp/wait-state -s v6 fd00:10:100:100::1 ESTABLISHED

# Routes to be imported using prefix match - check edge values and some in-betweens
gobgp/add-route -s v4 0.0.0.0/0
gobgp/add-route -s v4 10.0.0.0/24
gobgp/add-route -s v4 10.0.0.0/26
gobgp/add-route -s v4 10.0.0.0/28
gobgp/add-route -s v6 ::/0
gobgp/add-route -s v6 2001:db8::/64
gobgp/add-route -s v6 2001:db8::/72
gobgp/add-route -s v6 2001:db8::/80

# These routes shouldn't be imported because of invalid prefix lengths
gobgp/add-route -s v4 10.0.0.0/23
gobgp/add-route -s v4 10.0.0.0/29
gobgp/add-route -s v6 2001:db8::/63
gobgp/add-route -s v6 2001:db8::/81

# Routes to be imported using community match
gobgp/add-route -s v4 -c 65001:100 10.1.0.0/24
gobgp/add-route -s v6 -c 65001:100 2001:db8:1::/64
gobgp/add-route -s v4 -c 65001:200,65001:201,65001:200:200 10.2.0.0/24
gobgp/add-route -s v6 -c 65001:200,65001:201,65001:200:200 2001:db8:2::/64

# These routes shouldn't be imported because of missing / incomplete / invalid community
gobgp/add-route -s v4 10.3.0.0/24
gobgp/add-route -s v6 2001:db8:3::/64
gobgp/add-route -s v4 -c 999:999 10.4.0.0/26
gobgp/add-route -s v6 -c 999:999 2001:db8:4::/72
gobgp/add-route -s v4 -c 200:200 10.5.0.0/26
gobgp/add-route -s v6 -c 200:200 2001:db8:5::/72
gobgp/add-route -s v4 -c 65001:200:200 10.6.0.0/26
gobgp/add-route -s v6 -c 65001:200:200 2001:db8:6::/72

# Ensure all routes are in v4 server's RIB
gobgp/routes -s v4 -o gobgp-rib-v4.actual ipv4 unicast
* cmp gobgp-rib-v4.expected gobgp-rib-v4.actual

# Ensure all routes are in v6 server's RIB
gobgp/routes -s v6 -o gobgp-rib-v6.actual ipv6 unicast
* cmp gobgp-rib-v6.expected gobgp-rib-v6.actual

# Ensure expected v4 routes are imported
bgp/routes -o bgp-rib-v4.actual available ipv4 unicast
* cmp bgp-rib-v4.expected bgp-rib-v4.actual

# Ensure expected v6 routes are imported
bgp/routes -o bgp-rib-v6.actual available ipv6 unicast
* cmp bgp-rib-v6.expected bgp-rib-v6.actual

# Ensure routes are written into the RIB
db/cmp desired-routes desired-routes.expected

# Delete all servers
gobgp/delete-server v4
gobgp/delete-server v6

# Ensure routes are deleted
bgp/routes -o bgp-rib-v4.actual available ipv4 unicast
* cmp bgp-rib-empty.expected bgp-rib-v4.actual
bgp/routes -o bgp-rib-v6.actual available ipv6 unicast
* cmp bgp-rib-empty.expected bgp-rib-v6.actual

# Ensure routes are removed from the RIB
db/cmp desired-routes desired-routes-empty.expected

-- cilium-node.yaml --
apiVersion: cilium.io/v2
kind: CiliumNode
metadata:
  name: test-node

-- bgp-node-config.yaml --
apiVersion: isovalent.com/v1
kind: IsovalentBGPNodeConfig
metadata:
  name: test-node
spec:
  bgpInstances:
  - name: instance0
    localASN: 65001
    routerID: 5.6.7.8
    peers:
    - name: peer-v4
      peerASN: 65001
      peerAddress: 10.100.100.1
      peerConfigRef:
        name: peer-config-v4
    - name: peer-v6
      peerASN: 65001
      peerAddress: fd00:10:100:100::1
      peerConfigRef:
        name: peer-config-v6

-- bgp-peer-config-v4.yaml --
apiVersion: isovalent.com/v1
kind: IsovalentBGPPeerConfig
metadata:
  name: peer-config-v4
spec:
  transport:
    peerPort: 1790
  timers:
    connectRetryTimeSeconds: 1
  families:
  - afi: ipv4
    safi: unicast
    importPolicyRef:
      name: policy0

-- bgp-peer-config-v6.yaml --
apiVersion: isovalent.com/v1
kind: IsovalentBGPPeerConfig
metadata:
  name: peer-config-v6
spec:
  transport:
    peerPort: 1790
  timers:
    connectRetryTimeSeconds: 1
  families:
  - afi: ipv6
    safi: unicast
    importPolicyRef:
      name: policy0

-- bgp-policy.yaml --
apiVersion: isovalent.com/v1
kind: IsovalentBGPPolicy
metadata:
  name: policy0
spec:
  import:
    statements:

    # accept specific prefixes
    - conditions:
        prefixesV4:
          matchType: Or
          matches:
          - prefix: 10.0.0.0/24
            minLen: 24
            maxLen: 28
          - prefix: 0.0.0.0/0
        prefixesV6:
          matchType: Or
          matches:
          - prefix: 2001:db8::/64
            minLen: 64
            maxLen: 80
          - prefix: ::/0
      actions:
        routeAction: Accept

    # accept any prefixes with 65001:100 community
    - conditions:
        communities:
          matchType: Or
          matches:
          - community: 65001:100
      actions:
        routeAction: Accept

    # accept any prefixes with 65001:200 + 65001:201 community + 65001:200:200 large community
    - conditions:
        communities:
          matchType: And
          matches:
          - community: 65001:200
          - community: 65001:201
        largeCommunities:
          matchType: And
          matches:
          - community: 65001:200:200
      actions:
        routeAction: Accept

    # should not match any prefix
    - conditions:
        communities:
          matchType: Or
          matches:
          - wellKnown: blackhole
        largeCommunities:
          matchType: Not
          matches:
          - community: 65001:1111:2222
      actions:
        routeAction: Accept

-- bgp-policy.expected --
Instance    Policy Name                                Type     Match Peers          Match Families   Match Prefixes (Min..Max Len)                     Match Communities                                          RIB Action   Path Actions
instance0   allow-local                                import                                                                                                                                                      accept       
instance0   import-user-defined-peer-v4-ipv4-unicast   import   10.100.100.1         ipv4/unicast     (any) {0.0.0.0/0 (0..0)} {10.0.0.0/24 (24..28)}                                                              accept       
                                                                10.100.100.1         ipv4/unicast                                                       ^65001:100$                                                accept       
                                                                10.100.100.1         ipv4/unicast                                                       (all) {^65001:200$} {^65001:201$} Large: ^65001:200:200$   accept       
                                                                10.100.100.1         ipv4/unicast                                                       ^65535:666$ Large: (invert) ^65001:1111:2222$              accept       
instance0   import-user-defined-peer-v6-ipv6-unicast   import   fd00:10:100:100::1   ipv6/unicast     (any) {::/0 (0..0)} {2001:db8::/64 (64..80)}                                                                 accept       
                                                                fd00:10:100:100::1   ipv6/unicast                                                       ^65001:100$                                                accept       
                                                                fd00:10:100:100::1   ipv6/unicast                                                       (all) {^65001:200$} {^65001:201$} Large: ^65001:200:200$   accept       
                                                                fd00:10:100:100::1   ipv6/unicast                                                       ^65535:666$ Large: (invert) ^65001:1111:2222$              accept       
