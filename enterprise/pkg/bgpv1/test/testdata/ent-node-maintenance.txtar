#! --test-peering-ips=10.99.101.1,10.99.101.2 --enable-node-maintenance-helpers

# Tests service advertisements with node maintenance status changes (node cordon / uncordon).

# Start the hive
hive start

# Configure gobgp server
gobgp/add-server test 65010 10.99.101.1 1790

# Configure peers on GoBGP
gobgp/add-peer 10.99.101.2 65001

# Configure BGP on Cilium
k8s/add cilium-node.yaml k8s-node.yaml bgp-node-config.yaml bgp-peer-config.yaml bgp-advertisement.yaml service1.yaml
bgptest/sync-oss-resources

# Wait for peering to be established
gobgp/wait-state 10.99.101.2 ESTABLISHED

# Validate that svc IPs are advertised
gobgp/routes -o routes.actual
* cmp gobgp-routes-1.expected routes.actual

# Taint the node
k8s/update k8s-node-maintenance.yaml

# Validate that svc IPs are advertised with GS community
gobgp/routes -o routes.actual
* cmp gobgp-routes-gs-1.expected routes.actual

# Add 2nd service
k8s/add service2.yaml

# Validate that all svc IPs are still advertised with GS community
gobgp/routes -o routes.actual
* cmp gobgp-routes-gs-2.expected routes.actual

# Let maintenance time expire
sleep 1s

# Validate that all svc IPs are withdrawn
gobgp/routes -o routes.actual
* cmp gobgp-routes-empty.expected routes.actual

# Add 3rd service
k8s/add service3.yaml

# Validate that all svc IPs are still withdrawn
gobgp/routes -o routes.actual
* cmp gobgp-routes-empty.expected routes.actual

# Update node config with maintenance override - mode Community
k8s/update bgp-node-config-maintenance-community.yaml

# Validate that all svc IPs are advertised with GS community
gobgp/routes -o routes.actual
* cmp gobgp-routes-gs-3.expected routes.actual

# Update node config without maintenance override
k8s/update bgp-node-config.yaml

# Validate that all svc IPs are withdrawn
gobgp/routes -o routes.actual
* cmp gobgp-routes-empty.expected routes.actual

# Untaint the node
k8s/update k8s-node.yaml

# Validate that all svc IPs are advertised normally
gobgp/routes -o routes.actual
* cmp gobgp-routes-3.expected routes.actual

# Update node config with maintenance override - mode Community
k8s/update bgp-node-config-maintenance-community.yaml

# Validate that all svc IPs are advertised with GS community
gobgp/routes -o routes.actual
* cmp gobgp-routes-gs-3.expected routes.actual

# Update node config without maintenance override
k8s/update bgp-node-config.yaml

# Validate that all svc IPs still advertised normally
gobgp/routes -o routes.actual
* cmp gobgp-routes-3.expected routes.actual

#####

-- cilium-node.yaml --
apiVersion: cilium.io/v2
kind: CiliumNode
metadata:
  name: test-node
spec:
  addresses:
  - ip: 10.99.101.2
    type: InternalIP
  ipam:
    podCIDRs:
    - 10.244.1.0/24

-- k8s-node.yaml --
apiVersion: v1
kind: Node
metadata:
  name: test-node
spec:
  podCIDR: 10.244.1.0/24
  podCIDRs:
  - 10.244.1.0/24

-- k8s-node-maintenance.yaml --
apiVersion: v1
kind: Node
metadata:
  name: test-node
spec:
  podCIDR: 10.244.1.53/24
  podCIDRs:
  - 10.244.1.53/24
  taints:
  - effect: NoSchedule
    key: node.kubernetes.io/unschedulable
    timeAdded: "2025-06-23T13:54:44Z"

-- bgp-node-config.yaml --
apiVersion: isovalent.com/v1
kind: IsovalentBGPNodeConfig
metadata:
  name: test-node
spec:
  bgpInstances:
  - localASN: 65001
    name: tor-65001
    peers:
    - name: gobgp-peer-1
      peerASN: 65010
      peerAddress: 10.99.101.1
      localAddress: 10.99.101.2
      peerConfigRef:
        name: gobgp-peer-config

-- bgp-node-config-maintenance-community.yaml --
apiVersion: isovalent.com/v1
kind: IsovalentBGPNodeConfig
metadata:
  name: test-node
spec:
  bgpInstances:
  - localASN: 65001
    name: tor-65001
    maintenance:
      mode: Community
    peers:
    - name: gobgp-peer-1
      peerASN: 65010
      peerAddress: 10.99.101.1
      localAddress: 10.99.101.2
      peerConfigRef:
        name: gobgp-peer-config

-- bgp-peer-config.yaml --
apiVersion: isovalent.com/v1
kind: IsovalentBGPPeerConfig
metadata:
  name: gobgp-peer-config
spec:
  transport:
    peerPort: 1790
  timers:
    connectRetryTimeSeconds: 1
  families:
  - afi: ipv4
    safi: unicast
    advertisements:
      matchLabels:
        advertise: bgp

-- bgp-advertisement.yaml --
apiVersion: isovalent.com/v1
kind: IsovalentBGPAdvertisement
metadata:
  labels:
    advertise: bgp
  name: bgp-advertisements
spec:
  advertisements:
  - advertisementType: Service
    service:
      addresses:
      - LoadBalancerIP
      - ClusterIP
    selector:
      matchExpressions:
        - { key: bgp, operator: In, values: [ advertise ] }

-- service1.yaml --
apiVersion: v1
kind: Service
metadata:
  name: svc1
  namespace: test
  labels:
    bgp: advertise
spec:
  type: LoadBalancer
  clusterIP: 10.96.50.104
  clusterIPs:
  - 10.96.50.104
  externalTrafficPolicy: Cluster
  internalTrafficPolicy: Cluster
  ipFamilies:
  - IPv4
  ipFamilyPolicy: SingleStack
  ports:
  - name: http
    port: 80
    protocol: TCP
    targetPort: 80
  selector:
    name: echo
  sessionAffinity: None
status:
  loadBalancer:
    ingress:
    - ip: 172.16.1.1

-- service2.yaml --
apiVersion: v1
kind: Service
metadata:
  name: svc2
  namespace: test
  labels:
    bgp: advertise
spec:
  type: LoadBalancer
  clusterIP: 10.96.50.105
  clusterIPs:
  - 10.96.50.105
  externalTrafficPolicy: Cluster
  internalTrafficPolicy: Cluster
  ipFamilies:
  - IPv4
  ipFamilyPolicy: SingleStack
  ports:
  - name: http
    port: 80
    protocol: TCP
    targetPort: 80
  selector:
    name: echo
  sessionAffinity: None
status:
  loadBalancer:
    ingress:
    - ip: 172.16.1.2

-- service3.yaml --
apiVersion: v1
kind: Service
metadata:
  name: svc3
  namespace: test
  labels:
    bgp: advertise
spec:
  type: LoadBalancer
  clusterIP: 10.96.50.106
  clusterIPs:
  - 10.96.50.106
  externalTrafficPolicy: Cluster
  internalTrafficPolicy: Cluster
  ipFamilies:
  - IPv4
  ipFamilyPolicy: SingleStack
  ports:
  - name: http
    port: 80
    protocol: TCP
    targetPort: 80
  selector:
    name: echo
  sessionAffinity: None
status:
  loadBalancer:
    ingress:
    - ip: 172.16.1.3

-- gobgp-routes-1.expected --
Prefix            NextHop       Attrs
10.96.50.104/32   10.99.101.2   [{Origin: i} {AsPath: 65001} {Nexthop: 10.99.101.2}]
172.16.1.1/32     10.99.101.2   [{Origin: i} {AsPath: 65001} {Nexthop: 10.99.101.2}]
-- gobgp-routes-gs-1.expected --
Prefix            NextHop       Attrs
10.96.50.104/32   10.99.101.2   [{Origin: i} {AsPath: 65001} {Nexthop: 10.99.101.2} {Communities: planned-shut}]
172.16.1.1/32     10.99.101.2   [{Origin: i} {AsPath: 65001} {Nexthop: 10.99.101.2} {Communities: planned-shut}]
