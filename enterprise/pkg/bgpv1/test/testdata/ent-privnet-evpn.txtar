[type:Prefix][rd:10.99.103.1:1][etag:0][prefix:192.168.100.33/32]    10.99.103.1   [{Origin: ?} {AsPath: 65001} {Extcomms: [VXLAN], [65001:101], [router's mac: aa:bb:cc:dd:ee:ff]} {MpReach(l2vpn-evpn): {Nexthop: 10.99.103.1, NLRIs: [[type:Prefix][rd:10.99.103.1:1][etag:0][prefix:192.168.100.33/32]]}}]
[type:Prefix][rd:10.99.103.1:1][etag:0][prefix:fd10:0:100::33/128]   10.99.103.1   [{Origin: ?} {AsPath: 65001} {Extcomms: [VXLAN], [65001:101], [router's mac: aa:bb:cc:dd:ee:ff]} {MpReach(l2vpn-evpn): {Nexthop: 10.99.103.1, NLRIs: [[type:Prefix][rd:10.99.103.1:1][etag:0][prefix:fd10:0:100::33/128]]}}]
