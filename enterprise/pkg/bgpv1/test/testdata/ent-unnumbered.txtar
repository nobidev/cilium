#!

# Tests unnumbered BGP peering via link-local IPv6 addresses. The link-local
# address of the interfaces are always the same, because we generate it based
# on EUI64 and fixed MAC addresses. That's why we can directly write the
# address here.

# Start the hive
hive start
db/initialized

# Add devices and neighbors entries into statedb
db/insert devices device.yaml
db/insert neighbors neighbor.yaml

# Configure gobgp server (bind to :: as GoBGP does not support binding to a LL address with zone)
gobgp/add-server test --router-id=1.2.3.4 65001 :: 1799
gobgp/add-peer fe80::a800:ff:fe00:2%centbgptest1 65001

# Configure BGP on Cilium
k8s/add cilium-node.yaml bgp-node-config.yaml bgp-peer-config.yaml bgp-advertisement.yaml
bgptest/sync-oss-resources

# Wait for peering to be established
gobgp/wait-state fe80::a800:ff:fe00:2%centbgptest1 ESTABLISHED

# Validate IPv4 PodCIDR is advertised
gobgp/routes ipv4 unicast
* stdout 10.244.0.0/24

# Validate IPv6 PodCIDR is advertised
gobgp/routes ipv6 unicast
* stdout fd00:11:22::/64

#####

-- device.yaml --
index: 1
name: centbgptest2
type: veth
selected: true

-- neighbor.yaml --
linkindex: 1
ipaddr: fe80::a800:ff:fe00:1
type: 1
state: 0x80
flags: 0x10
flagsExt: 0x0

-- cilium-node.yaml --
apiVersion: cilium.io/v2
kind: CiliumNode
metadata:
  name: test-node
spec:
  addresses:
  - ip: fd00::aa:aa:aa:102
    type: InternalIP
  ipam:
    podCIDRs:
    - 10.244.0.0/24
    - fd00:11:22::/64

-- bgp-node-config.yaml --
apiVersion: isovalent.com/v1
kind: IsovalentBGPNodeConfig
metadata:
  name: test-node
spec:
  bgpInstances:
  - localASN: 65001
    routerID: 5.6.7.8
    name: tor
    peers:
    - name: gobgp-peer
      peerASN: 65001
      autoDiscovery:
        mode: Unnumbered
        unnumbered:
          interface: centbgptest2
      peerConfigRef:
        name: gobgp-peer-config

-- bgp-peer-config.yaml --
apiVersion: isovalent.com/v1
kind: IsovalentBGPPeerConfig
metadata:
  name: gobgp-peer-config
spec:
  transport:
    peerPort: 1799
  timers:
    connectRetryTimeSeconds: 1
  families:
  - afi: ipv4
    safi: unicast
    advertisements:
      matchLabels:
        advertise: bgp
  - afi: ipv6
    safi: unicast
    advertisements:
      matchLabels:
        advertise: bgp

-- bgp-advertisement.yaml --
apiVersion: isovalent.com/v1
kind: IsovalentBGPAdvertisement
metadata:
  labels:
    advertise: bgp
  name: bgp-advertisements
spec:
  advertisements:
  - advertisementType: PodCIDR
