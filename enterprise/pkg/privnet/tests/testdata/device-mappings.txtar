#! --private-networks-enabled --private-networks-mode=bridge

# Mark endpoint restoration as finished.
privnet/epm-finish-restoration

hive start
db/initialized private-networks
db/initialized privnet-local-workloads
db/initialized privnet-device-mappings

db/insert devices device.eth1.yaml device.eth2.yaml device.eth4.yaml

# Add two ClusterwidePrivateNetworks
k8s/add icpn-1.yaml icpn-2.yaml
k8s/add pnna-1.yaml pnna-2.yaml

# Ensure that they are correctly propagated into the device-mappings table
# Entries for united-firefly should not be present, as the corresponding
# device entry has not been inserted yet.
db/cmp privnet-device-mappings device-mappings.v1.table

# Ensure that the entries are propagated into the corresponding BPF map.
privnet/maps-dump privnet_devices devices-actual.map
* cmp devices.v1.map devices-actual.map

# Insert the eth3 device, entries for united-firefly should be now present.
db/insert devices device.eth3.yaml
db/cmp privnet-device-mappings device-mappings.v2.table

# Ensure that the entries are propagated into the corresponding BPF map.
privnet/maps-dump privnet_devices devices-actual.map
* cmp devices.v2.map devices-actual.map

# Update one of the networks, and assert that updates are propagated.
cp pnna-2.yaml pnna-2.v2.yaml
replace eth3 eth4 pnna-2.v2.yaml
k8s/update pnna-2.v2.yaml
db/cmp privnet-device-mappings device-mappings.v3.table

# Ensure that the entries are propagated into the corresponding BPF map.
privnet/maps-dump privnet_devices devices-actual.map
* cmp devices.v3.map devices-actual.map

# Add one more network, and assert that updates are propagated
k8s/add icpn-3.yaml pnna-3.yaml
db/cmp privnet-device-mappings device-mappings.v4.table

# Ensure that the entries are propagated into the corresponding BPF map.
privnet/maps-dump privnet_devices devices-actual.map
* cmp devices.v4.map devices-actual.map

# Remove one of the devices, and one of the networks, and assert that updates
# are propagated
k8s/delete icpn-3.yaml
db/delete devices device.eth4.yaml
db/cmp privnet-device-mappings device-mappings.v1.table

# Ensure that the entries are propagated into the corresponding BPF map.
privnet/maps-dump privnet_devices devices-actual.map
* cmp devices.v1.map devices-actual.map

# Create a bunch of endpoints, and assert that the entries are propagated.
privnet/epm-create ep-speedy-cheetah.json
privnet/epm-create ep-sleepy-sloth.json
db/cmp privnet-device-mappings device-mappings.v5.table

# Ensure that the entries are propagated into the corresponding BPF map.
privnet/maps-dump privnet_devices devices-actual.map
* cmp devices.v5.map devices-actual.map

# Add one more one endpoint, and delete another, and assert that updates are propagated.
privnet/epm-create ep-clever-fox.json
privnet/epm-delete qux/sleepy-sloth
db/cmp privnet-device-mappings device-mappings.v6.table

# Ensure that the entries are propagated into the corresponding BPF map.
privnet/maps-dump privnet_devices devices-actual.map
* cmp devices.v6.map devices-actual.map

# Delete one of the networks, and assert that entries are updated as expected.
k8s/delete icpn-1.yaml
db/cmp privnet-device-mappings device-mappings.v7.table

# Ensure that the entries are propagated into the corresponding BPF map.
privnet/maps-dump privnet_devices devices-actual.map
* cmp devices.v7.map devices-actual.map

# Create it again, and assert that the entries are updated as expected.
k8s/add icpn-1.yaml
db/cmp privnet-device-mappings device-mappings.v8.table

# Ensure that the entries are propagated into the corresponding BPF map.
privnet/maps-dump privnet_devices devices-actual.map
* cmp devices.v8.map devices-actual.map

# ---

-- device.eth1.yaml --
index: 10
name: eth1
type: veth
operstatus: up
selected: true

-- device.eth2.yaml --
index: 20
name: eth2
type: veth
operstatus: up
selected: true

-- device.eth3.yaml --
index: 30
name: eth3
type: veth
operstatus: up
selected: true

-- device.eth4.yaml --
index: 40
name: eth4
type: veth
operstatus: up
selected: true

-- icpn-1.yaml --
apiVersion: isovalent.com/v1alpha1
kind: ClusterwidePrivateNetwork
metadata:
  name: direct-maggot
spec:
  subnets:
  - name: foo
    cidrv4: 192.168.250.0/24
    cidrv6: fd10:0:250::0/64
  - name: bar
    cidrv4: 192.168.251.0/24
    cidrv6: fd10:0:251::0/64

-- pnna-1.yaml --
apiVersion: isovalent.com/v1alpha1
kind: PrivateNetworkNodeAttachment
metadata:
  name: direct-maggot-na
spec:
  privateNetworkRef:
    name: direct-maggot
  attachments:
    - interface: eth1
      subnetRefs:
        - name: foo
    - interface: eth2
      subnetRefs:
        - name: bar

-- icpn-2.yaml --
apiVersion: isovalent.com/v1alpha1
kind: ClusterwidePrivateNetwork
metadata:
  name: united-firefly
spec:
  subnets:
  - name: foo
    cidrv4: 192.168.250.0/24
    cidrv6: fd10:0:250::0/64

-- pnna-2.yaml --
apiVersion: isovalent.com/v1alpha1
kind: PrivateNetworkNodeAttachment
metadata:
  name: united-firefly-na
spec:
  privateNetworkRef:
    name: united-firefly
  attachments:
    - interface: eth3
      subnetRefs:
        - name: foo

-- icpn-3.yaml --
apiVersion: isovalent.com/v1alpha1
kind: ClusterwidePrivateNetwork
metadata:
  name: notable-goose
spec:
  subnets:
  - name: foo
    cidrv4: 192.168.251.0/24

-- pnna-3.yaml --
apiVersion: isovalent.com/v1alpha1
kind: PrivateNetworkNodeAttachment
metadata:
  name: notable-goose-na
spec:
  privateNetworkRef:
    name: notable-goose
  attachments:
    - interface: eth3
      subnetRefs:
        - name: foo

