#! --private-networks-enabled

# Create the health servers.
serverpool/new felidae/cougar
serverpool/new camelidae/alpaca

hive start

# Configure the networks served by each INB.
serverpool/serve felidae/cougar   blue-network green-network
serverpool/serve camelidae/alpaca blue-network green-network

# Start all health servers.
serverpool/start felidae/cougar
serverpool/start camelidae/alpaca

# Ingest initial blue private network and initial endpoint slice (containing blue and green endpoints)
k8s/add icpn-blue.v1.yaml
k8s/add privnet-eps.v1.yaml

# Ingest the endpoints from clustermesh.
clustermesh/endpoints/upsert blue-network/10.245.8.21 endpoint-felidae-cougar-1.json
clustermesh/endpoints/upsert blue-network/10.245.8.87 endpoint-felidae-cougar-2.json
clustermesh/endpoints/upsert blue-network/10.245.9.41 endpoint-camelidae-alpaca-1.json

# Observe INB node information from clustermesh (the etcd key is omitted as unused).
clustermesh/nodes/upsert _ nodes-felidae-cougar.json
clustermesh/nodes/upsert _ nodes-camelidae-alpaca.json
clustermesh/nodes/sync

# Wait for initial table to be populated
db/cmp privnet-mapentries mapentries.v1.table

# Mark clustermesh endpoints synchronized - this should transitively also initialize the privnet-mapentries table
clustermesh/endpoints/sync
db/initialized privnet-mapentries

# Add green private network - this should also cause the green endpoints to be upserted
k8s/add icpn-green.v1.yaml

# Wait for green entries to be upserted
db/cmp privnet-mapentries mapentries.v2.table

# Upsert four conflicting endpoints:
# - blue:192.168.250.20 gets a Net-IP conflicting (newer) endpoint
# - blue:192.168.250.21 gets a Pod-IP conflicting (newer) endpoint
# - blue:192.168.250.24 is a new endpoint which shadows a subnet entry
# - green:10.0.100.30 gets a Net-IP conflicting (but older) endpoint
k8s/add privnet-alt-eps.v1.yaml
db/cmp privnet-mapentries mapentries.v3.table

# Change original endpoints:
# - green:10.0.100.30 is removed (this bubbles up the newer endpoint from above)
# - green:10.0.100.31 becomes inactive
# - blue:192.168.250.{20,21} are removed (both endpoints were already shadowed)
# - blue:192.168.250.251 is removed
# - blue:192.168.250.252 is added
k8s/add privnet-eps.v2.yaml
clustermesh/endpoints/delete blue-network/10.245.8.87 endpoint-felidae-cougar-2.json
clustermesh/endpoints/upsert blue-network/10.245.8.92 endpoint-felidae-cougar-3.json
db/cmp privnet-mapentries mapentries.v4.table

# Delete original slice. Since its only endpoint is inactive, there should be no changes
k8s/delete privnet-eps.v2.yaml
db/cmp privnet-mapentries mapentries.v4.table

# Delete green network
k8s/delete icpn-green.v1.yaml
db/cmp privnet-mapentries mapentries.v5.table

# Add routes and change subnets in network blue
k8s/add icpn-blue.v2.yaml
db/cmp privnet-mapentries mapentries.v6.table

# Delete remaining endpoints in blue network (this should unshadow a subnet route)
k8s/delete privnet-alt-eps.v1.yaml
db/cmp privnet-mapentries mapentries.v7.table

# Change the target INB in network blue, and assert that mapentries are correctly updated.
cp icpn-blue.v2.yaml icpn-blue.v3.yaml
sed 'felidae' 'camelidae' icpn-blue.v3.yaml
k8s/update icpn-blue.v3.yaml
db/cmp privnet-mapentries mapentries.v8.table

# Remove all INBs in network blue, all remaining entries should be deleted.
k8s/update icpn-blue.v4.yaml
* db/empty privnet-mapentries

# ---

-- icpn-blue.v1.yaml --
apiVersion: isovalent.com/v1alpha1
kind: ClusterwidePrivateNetwork
metadata:
  name: blue-network
spec:
  networkBridges:
  - cluster: felidae
  routes: []
  subnets:
  - cidr: 192.168.250.0/24
  - cidr: fd10:0:250::0/64
  - cidr: 192.168.250.24/32

-- icpn-blue.v2.yaml --
apiVersion: isovalent.com/v1alpha1
kind: ClusterwidePrivateNetwork
metadata:
  name: blue-network
spec:
  networkBridges:
  - cluster: felidae
  routes:
  - destination: 192.168.252.0/24
    gateway: 192.168.250.2
  - destination: 0.0.0.0/0
    gateway: 192.168.250.1
  subnets:
  - cidr: 192.168.250.0/23
  - cidr: fd10:0:250::0/64
  - cidr: 192.168.250.24/32

-- icpn-blue.v4.yaml --
apiVersion: isovalent.com/v1alpha1
kind: ClusterwidePrivateNetwork
metadata:
  name: blue-network
spec:
  routes:
  - destination: 192.168.252.0/24
    gateway: 192.168.250.2
  - destination: 0.0.0.0/0
    gateway: 192.168.250.1
  subnets:
  - cidr: 192.168.250.0/23
  - cidr: fd10:0:250::0/64
  - cidr: 192.168.250.24/32

-- icpn-green.v1.yaml --
apiVersion: isovalent.com/v1alpha1
kind: ClusterwidePrivateNetwork
metadata:
  name: green-network
spec:
  networkBridges:
  - cluster: camelidae
  routes: []
  subnets:
  - cidr: 10.0.100.0/24
  - cidr: fd00:10:100::0/64

-- privnet-eps.v1.yaml --
apiVersion: isovalent.com/v1alpha1
kind: PrivateNetworkEndpointSlice
metadata:
  namespace: default
  name: privnet-eps-1
endpoints:
- activatedAt: "2025-06-20T15:54:04.501000Z"
  endpoint:
    addressing:
      ipv4: 10.244.5.108
      ipv6: fd00:10:244:5::108
    name: optimum-mouse
  interface:
    addressing:
      ipv4: 192.168.250.20
      ipv6: fd10:0:250::20
    mac: 00:50:56:ad:45:ec
    network: blue-network
- activatedAt: "2025-06-20T15:54:03.421000Z"
  endpoint:
    addressing:
      ipv4: 10.244.5.109
      ipv6: fd00:10:244:5::109
    name: regular-koi
