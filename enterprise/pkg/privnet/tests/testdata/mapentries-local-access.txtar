#! --private-networks-enabled --private-networks-mode=local-access

hive start
db/initialized private-networks privnet-routes privnet-subnets

# Setup devices
db/insert devices device.eth1.yaml
db/insert devices device.eth2.yaml
db/insert devices device.eth3.yaml

# Add two ClusterwidePrivateNetworks
k8s/add icpn-1.yaml icpn-2.yaml
k8s/add pnna-1.yaml pnna-2.yaml

# test 1: check initial state is populated correctly with associated egress interfaces
db/cmp privnet-subnets subnets.v1.table
db/cmp privnet-mapentries mapentries.v1.table

# test 2: setup local and remote endpoints and validate L2Ann flag
k8s/add direct-maggot-other-ep.yaml
privnet/epm-create ep-speedy-cheetah.json
db/cmp privnet-mapentries mapentries.v2.table

# test 3: update ifindex of eth1 ( devices table has index as key, changing it requires del/add)
db/delete devices device.eth1.yaml
replace 'index: 10' 'index: 11' device.eth1.yaml
db/insert devices device.eth1.yaml
db/cmp privnet-subnets subnets.v3.table
db/cmp privnet-mapentries mapentries.v3.table

# test 4: remove node-attachment
k8s/delete pnna-2.yaml

db/cmp privnet-subnets subnets.v4.table
db/cmp privnet-mapentries mapentries.v4.table


# ----

-- device.eth1.yaml --
index: 10
name: eth1
type: veth
operstatus: up
selected: true

-- device.eth2.yaml --
index: 20
name: eth2
type: veth
operstatus: up
selected: true

-- device.eth3.yaml --
index: 30
name: eth3
type: veth
operstatus: up
selected: true

-- icpn-1.yaml --
apiVersion: isovalent.com/v1alpha1
kind: ClusterwidePrivateNetwork
metadata:
  name: direct-maggot
spec:
  subnets:
  - name: subnet1
    cidrv4: 192.168.250.0/24
    cidrv6: fd10:0:250::0/64
    routes:
    - destination: 192.168.252.0/24
      gateway: 192.168.250.254
    - destination: fd10:0:252::/64
      gateway: fd10:0:250::fffe
  - name: subnet2
    cidrv4: 10.10.250.0/24
    cidrv6: fd10:10:250::0/64
    routes:
    - destination: 10.10.252.0/24
      gateway: 10.10.250.254
    - destination: fd10:10:252::/64
      gateway: fd10:10:250::fffe

-- pnna-1.yaml --
apiVersion: isovalent.com/v1alpha1
kind: PrivateNetworkNodeAttachment
metadata:
  name: direct-maggot-na
spec:
  privateNetworkRef:
    name: direct-maggot
  attachments:
    - interface: eth1
      subnetRefs:
        - name: subnet1
    - interface: eth2
      subnetRefs:
        - name: subnet2

-- icpn-2.yaml --
apiVersion: isovalent.com/v1alpha1
kind: ClusterwidePrivateNetwork
metadata:
  name: united-firefly
spec:
  subnets:
  - name: subnet1
    cidrv4: 192.168.251.0/24
  - name: subnet2
    cidrv4: 10.10.251.0/24

-- pnna-2.yaml --
apiVersion: isovalent.com/v1alpha1
kind: PrivateNetworkNodeAttachment
metadata:
  name: united-firefly-na
spec:
  privateNetworkRef:
    name: united-firefly
  attachments:
    - interface: eth3
      subnetRefs:
        - name: subnet1
        - name: subnet2

-- ep-speedy-cheetah.json --
{
  "ID": 16,
  "addressing": {
    "ipv4": "10.244.5.116",
    "ipv6": "fd00:10:244:5::116"
  },
  "k8s-pod-name": "speedy-cheetah",
  "k8s-namespace": "bar",
  "mac": "00:50:56:ad:11:02",
  "properties": {
    "isovalent-privnet-network": "direct-maggot",
    "isovalent-privnet-activated-at": "2025-09-17T12:41:00.000000Z",
    "isovalent-privnet-ipv4-addr": "192.168.250.10",
    "isovalent-privnet-ipv6-addr": "fd10:0:250::10"
  }
}

-- direct-maggot-other-ep.yaml --
apiVersion: isovalent.com/v1alpha1
kind: PrivateNetworkEndpointSlice
metadata:
  namespace: default
  name: direct-maggot-other-ep
endpoints:
- activatedAt: "2025-06-20T16:00:01.000000Z"
  endpoint:
    addressing:
      ipv4: 10.244.5.108
      ipv6: fd10:0:250::23
    name: gracious-gerbil
  interface:
    addressing:
      ipv4: 192.168.250.4
      ipv6: fd10:0:250::4
    mac: 00:50:56:ad:11:97
    network: direct-maggot
nodeName: cricket

