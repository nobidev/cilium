#! --private-networks-enabled

hive start
db/initialized private-networks privnet-routes privnet-subnets

# Add two ClusterwidePrivateNetworks
k8s/add icpn-1.yaml icpn-2.yaml

# Ensure that they are correctly propagated into the table
db/cmp private-networks privnet.table
db/cmp privnet-routes routes.table
db/cmp privnet-subnets subnets.table

# Ensure that all the fields are propagated correctly
db/get private-networks direct-maggot -f yaml -o privnet.direct-maggot.actual.yaml
cmp privnet.direct-maggot.actual.yaml privnet.direct-maggot.expected.yaml

# Update one ClusterwidePrivateNetwork, and assert that the update is propagated
cp icpn-2.yaml icpn-2.v2.yaml
replace '192.168.251.0/24' '192.168.252.0/24' icpn-2.v2.yaml
k8s/update icpn-2.v2.yaml
db/cmp private-networks privnet.table.v2
db/cmp privnet-routes routes.table.v2
db/cmp privnet-subnets subnets.table.v2

# Delete one ClusterwidePrivateNetwork, and assert that the deletion is propagated
k8s/delete icpn-1.yaml
db/cmp private-networks privnet.table.v3
db/cmp privnet-routes routes.table.v3
db/cmp privnet-subnets subnets.table.v3

# Add it back, and assert that it is present again (although with a different ID)
k8s/add icpn-1.yaml
db/cmp private-networks privnet.table.v4
db/cmp privnet-routes routes.table.v2
db/cmp privnet-subnets subnets.table.v4

# Add VPC like privnet with multiple subnets
k8s/add icpn-vpc-1.yaml
db/cmp privnet-subnets subnets.table.vpc1
db/cmp privnet-routes routes.table.vpc1

# Add subnet to privnet
k8s/add icpn-vpc-2.yaml
db/cmp privnet-subnets subnets.table.vpc2
db/cmp privnet-routes routes.table.vpc2

# Remove subnet and add conflicting subnet to privnet, assert that conflicts don't show up
k8s/add icpn-vpc-3.yaml
db/cmp privnet-subnets subnets.table.vpc3
db/cmp privnet-routes routes.table.vpc3

# Remove subnets, assert that previously filtered out conflicts show up
k8s/add icpn-vpc-4.yaml
db/cmp privnet-subnets subnets.table.vpc4
db/cmp privnet-routes routes.table.vpc4

# ---

-- icpn-1.yaml --
apiVersion: isovalent.com/v1alpha1
kind: ClusterwidePrivateNetwork
metadata:
  name: direct-maggot
spec:
  interface: {}
  networkBridges:
  - cluster: felidae
    nodeSelector:
      matchLabels:
        kubernetes.io/arch: amd64
  - cluster: elephantidae
  subnets:
  - name: subnet1
    cidrv4: 192.168.250.0/24
    cidrv6: fd10:0:250::0/64
    routes:
    - destination: 192.168.252.0/24
      gateway: 192.168.250.254
    - destination: fd10:0:252::/64
      gateway: fd10:0:250::fffe
    - destination: 192.168.255.0/24
      gateway: 192.168.250.200
    - destination: fd10:0:255::/64
      gateway: fd10:0:250::200
status:
  vni: 100

-- icpn-2.yaml --
apiVersion: isovalent.com/v1alpha1
kind: ClusterwidePrivateNetwork
metadata:
  name: united-firefly
spec:
  interface:
    name: eth1
  networkBridges:
  - cluster: camelidae
  subnets:
  - name: subnet2
    cidrv4: 192.168.251.0/24
status:
  vni: 200

-- icpn-vpc-1.yaml --
apiVersion: isovalent.com/v1alpha1
kind: ClusterwidePrivateNetwork
metadata:
  name: vpc
spec:
  networkBridges:
  - cluster: camelidae
  subnets:
  - name: blue
    cidrv4: 192.168.251.0/24
    cidrv6: fd10:0:251::/64
    routes:
    - destination: 0.0.0.0/0
      gateway: 192.168.251.1
    - destination: ::/0
      gateway: fd10:0:251::1
    # Should be filtered out because it's the same key, just different
    - destination: 0.0.1.2/0
      gateway: 192.168.252.8
  - name: red
    cidrv4: 192.168.252.0/24
    cidrv6: fd10:0:252::/64
    routes:
    - destination: 0.0.0.0/0
      gateway: 192.168.252.1
    - destination: ::/0
      gateway: fd10:0:252::1

-- icpn-vpc-2.yaml --
apiVersion: isovalent.com/v1alpha1
kind: ClusterwidePrivateNetwork
metadata:
  name: vpc
spec:
  networkBridges:
  - cluster: camelidae
  subnets:
  - name: blue
    cidrv4: 192.168.251.0/24
    cidrv6: fd10:0:251::/64
    routes:
    - destination: 0.0.0.0/0
      gateway: 192.168.251.2
    - destination: ::/0
      gateway: fd10:0:251::2
  - name: red
    cidrv4: 192.168.252.0/24
    cidrv6: fd10:0:252::/64
    routes:
    - destination: 0.0.0.0/0
      gateway: 192.168.252.2
    - destination: ::/0
      gateway: fd10:0:252::2
  - name: green
    cidrv4: 192.168.253.0/24
    cidrv6: fd10:0:253::/64
    routes:
    - destination: 10.0.0.0/8
      gateway: 192.168.253.2
    - destination: ::/0
      gateway: fd10:0:253::2

-- icpn-vpc-3.yaml --
apiVersion: isovalent.com/v1alpha1
kind: ClusterwidePrivateNetwork
metadata:
  name: vpc
spec:
  networkBridges:
  - cluster: camelidae
  subnets:
  - name: blue
    cidrv4: 192.168.251.0/24
    cidrv6: fd10:0:251::/64
  - name: red
    cidrv4: 192.168.252.0/24
    cidrv6: fd10:0:252::/64
  - name: red2
    cidrv4: 192.168.252.0/30
    cidrv6: fd10:0:1::/64
  - name: blue2
    cidrv4: 192.168.1.0/24
    cidrv6: fd10:0:251::/64
  - name: yellow
    cidrv4: 192.168.100.0/24
    cidrv6: fd10:0:100::/64

-- icpn-vpc-4.yaml --
apiVersion: isovalent.com/v1alpha1
kind: ClusterwidePrivateNetwork
metadata:
  name: vpc
spec:
  networkBridges:
  - cluster: camelidae
  subnets:
  - name: red2
    cidrv4: 192.168.252.0/30
    cidrv6: fd10:0:1::/64
  - name: blue2
    cidrv4: 192.168.1.0/24
    cidrv6: fd10:0:251::/64
  - name: yellow
    cidrv4: 192.168.100.0/24
    cidrv6: fd10:0:100::/64

