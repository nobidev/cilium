-- privnet.direct-maggot.expected.yaml --
name: direct-maggot
id: 1
vni: 100
inbs:
    selectors:
        elephantidae: ""
        felidae: kubernetes.io/arch=amd64
interface:
    name: ""
    index: 0
    error: ""
    conflict: false
subnets:
    - name: subnet1
      cidrv4: 192.168.250.0/24
      cidrv6: fd10:0:250::/64
      routes:
        - destination: 192.168.252.0/24
          gateway: 192.168.250.254
          evpngateway: false
        - destination: fd10:0:252::/64
          gateway: fd10:0:250::fffe
          evpngateway: false
        - destination: 192.168.255.0/24
          gateway: 192.168.250.200
          evpngateway: false
        - destination: fd10:0:255::/64
          gateway: fd10:0:250::200
          evpngateway: false
