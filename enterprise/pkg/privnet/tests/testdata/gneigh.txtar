-- gneigh.expected.v1.table --
Type   Interface   MAC               IP
ARP    eth2        12:42:ac:ab:00:02 192.168.99.49
ARP    eth1        12:42:ac:ab:00:01 192.168.251.24
ND     eth1        12:42:ac:ab:00:01 fd00:10:244:5::98

-- gneigh.expected.v2.table --
Type   Interface   MAC               IP
ARP    eth2        12:42:ac:ab:00:02 192.168.99.49
ARP    eth1        12:42:ac:ab:00:01 192.168.251.24
ARP    eth1        12:42:ac:ab:00:01 192.168.251.25
ND     eth1        12:42:ac:ab:00:01 fd00:10:244:5::98
ND     eth1        12:42:ac:ab:00:01 fd00:10:244:5::99

-- gneigh.expected.v3.table --
Type   Interface   MAC               IP
ARP    eth2        12:42:ac:ab:00:02 192.168.99.49
