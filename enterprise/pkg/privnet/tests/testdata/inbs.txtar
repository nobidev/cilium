#! --private-networks-enabled

# Populate the INBs checkpoint, to verify that associations are preserved.
cp checkpoint.prev.json privnet-active-inbs.json

hive start

# Add two ClusterwidePrivateNetworks
k8s/add icpn-blue.v1.yaml icpn-red.v1.yaml

# Observe nodes from clustermesh (the etcd key is omitted as unused).
clustermesh/nodes/upsert _ nodes-felidae-cougar.json
clustermesh/nodes/upsert _ nodes-felidae-lion.json
clustermesh/nodes/upsert _ nodes-felidae-tiger.json
clustermesh/nodes/upsert _ nodes-camelidae-llama.json
clustermesh/nodes/upsert _ nodes-elephantidae-elephant.json
clustermesh/nodes/upsert _ nodes-elephantidae-mammoth.json

# The INBs table should have been populated with the initial state.
# No INB is still marked as active, as initialization did not complete yet.
db/cmp privnet-inbs inbs.v1.table

# The private privnet-inbs table should not be initialized, as
# we haven't synchronized with clustermesh yet.
db/initialized private-networks
! db/initialized --timeout 0 privnet-inbs

# The table should be marked as initialized at this point.
clustermesh/nodes/sync
db/initialized privnet-inbs

# The active INBs should have been reconciled at this point.
db/cmp privnet-inbs inbs.v2.table
* cmp privnet-active-inbs.json checkpoint.v2.json


# Observe a few more node updates and deletions, and assert that
# the table is updated correctly.
replace arm64 amd64 nodes-felidae-cougar.json   # Now matched by privnet blue
replace amd64 s390x nodes-camelidae-llama.json  # No longer matched by privnet red
replace 192.168.0.1 192.168.255.1 nodes-felidae-lion.json

clustermesh/nodes/upsert _ nodes-camelidae-alpaca.json
clustermesh/nodes/upsert _ nodes-camelidae-llama.json
clustermesh/nodes/upsert _ nodes-felidae-cougar.json
clustermesh/nodes/upsert _ nodes-felidae-lion.json
clustermesh/nodes/delete _ nodes-felidae-tiger.json

db/cmp privnet-inbs inbs.v3.table
* cmp privnet-active-inbs.json checkpoint.v3.json


# Update the privnet resources, and assert that the table is updated correctly.
k8s/update icpn-blue.v2.yaml  # Change the selector of felidae, remove camelidae
k8s/update icpn-red.v2.yaml   # Change the selector of felidae and camelidae, add elephantidae

db/cmp privnet-inbs inbs.v4.table
* cmp privnet-active-inbs.json checkpoint.v4.json


# Delete one of the privnet resources, and assert that the table is updated correctly.
k8s/delete icpn-red.v2.yaml
db/cmp privnet-inbs inbs.v5.table
* cmp privnet-active-inbs.json checkpoint.v5.json

# Delete the other one as well, the table should be now empty.
k8s/delete icpn-blue.v2.yaml
* db/empty privnet-inbs
* db/empty private-networks
* cmp privnet-active-inbs.json checkpoint.v6.json

# Add them back again, the table should converge again to the previous state.
k8s/add icpn-blue.v2.yaml icpn-red.v2.yaml

# Strictly speaking, there's no hard guarantee on which INB node gets picked
# as active, as healthiness events may be observed in different batches.
db/cmp privnet-inbs inbs.v6.table

# Additionally, verify that both networks have an active INB. We check them
# independently because their order is not guaranteed depending on which node
# gets picked as active.
db/get --index network-role --columns Network privnet-inbs blue|A
* stdout blue
db/get --index network-role --columns Network privnet-inbs red|A
* stdout red

# ---

-- icpn-blue.v1.yaml --
apiVersion: isovalent.com/v1alpha1
kind: ClusterwidePrivateNetwork
metadata:
  name: blue
spec:
  networkBridges:
    - cluster: felidae
      nodeSelector:
        matchLabels:
          kubernetes.io/arch: amd64
    - cluster: camelidae
    - cluster: elephantidae
  subnets:
    - cidr: 192.168.250.0/24

-- icpn-blue.v2.yaml --
apiVersion: isovalent.com/v1alpha1
kind: ClusterwidePrivateNetwork
metadata:
  name: blue
spec:
  networkBridges:
    - cluster: felidae
    - cluster: elephantidae
  subnets:
    - cidr: 192.168.250.0/24

-- icpn-red.v1.yaml --
apiVersion: isovalent.com/v1alpha1
kind: ClusterwidePrivateNetwork
metadata:
  name: red
spec:
  networkBridges:
    - cluster: felidae
      nodeSelector:
        matchExpressions:
          - key: node-role.kubernetes.io/control-plane
            operator: DoesNotExist
    - cluster: camelidae
      nodeSelector:
        matchExpressions:
          - key: kubernetes.io/arch
            operator: In
            values:
              - amd64
              - arm64
  subnets:
    - cidr: 192.168.251.0/24

-- icpn-red.v2.yaml --
apiVersion: isovalent.com/v1alpha1
kind: ClusterwidePrivateNetwork
metadata:
  name: red
spec:
  networkBridges:
    - cluster: felidae
      nodeSelector:
        matchExpressions:
          - key: node-role.kubernetes.io/control-plane
            operator: Exists
    - cluster: camelidae
      nodeSelector:
        matchExpressions:
          - key: kubernetes.io/arch
            operator: Exists
        matchLabels:
          kubernetes.io/hostname: llama
    - cluster: elephantidae
  subnets:
    - cidr: 192.168.251.0/24

