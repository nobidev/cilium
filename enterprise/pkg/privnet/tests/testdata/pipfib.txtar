#! --cluster-name=foobar --private-networks-enabled

hive start

db/insert privnet-mapentries mapentries.v1.yaml

# The mapentries table is not initialized yet
! db/initialized --timeout 0 privnet-mapentries

# Ensure that the FIB map is populated
privnet/maps-dump privnet_fib fib-actual.map
* cmp fib.v0.map fib-actual.map

# Ensure that the PIB map is populated
privnet/maps-dump privnet_pip pip-actual.map
* cmp pip.v0.map pip-actual.map

# Let the mapentries table be marked as initialized
clustermesh/endpoints/sync
clustermesh/nodes/sync
db/initialized privnet-mapentries

# Ensure that the stale FIB map entries are pruned
privnet/maps-dump privnet_fib fib-actual.map
* cmp fib.v1.map fib-actual.map

# Ensure that the stale PIP map entries are pruned
privnet/maps-dump privnet_pip pip-actual.map
* cmp pip.v1.map pip-actual.map

db/delete privnet-mapentries mapentries.v1.delete.yaml

# Ensure that the deleted FIB map entry is removed
privnet/maps-dump privnet_fib fib-actual.map
* cmp fib.v2.map fib-actual.map

# Ensure that the delete PIP map entry is removed 
privnet/maps-dump privnet_pip pip-actual.map
* cmp pip.v2.map pip-actual.map

-- mapentries.v1.yaml --
