#! --private-networks-enabled --private-networks-mode=bridge

# Create the checkers.
checkerpool/new cougar felidae/cougar
checkerpool/new lion   felidae/lion

hive start

# Populate the initial state.
db/insert devices device.eth1.yaml
db/insert devices device.eth2.yaml
k8s/add icpn-1.yaml icpn-2.yaml

# Register the networks.
checkerpool/register cougar default/foobar-worker-1 firefly
checkerpool/register cougar default/foobar-worker-1 maggot
checkerpool/synced cougar
db/cmp test-observed-state-cougar health.v1.table

checkerpool/register lion default/foobar-worker-1 firefly
checkerpool/register lion default/foobar-worker-1 maggot
checkerpool/synced lion
db/cmp test-observed-state-lion health.v1.table

# Create a few local workloads.
db/insert privnet-local-workloads local-workload-optimum-mouse.yaml
db/insert privnet-local-workloads local-workload-shining-burro.yaml

# Ingest the endpoints from endpointslices and clustermesh.
k8s/add privnet-eps.yaml
clustermesh/endpoints/upsert maggot/10.245.8.21 endpoint-maggot-cougar-1.json
clustermesh/endpoints/upsert maggot/10.245.8.22 endpoint-maggot-cougar-2.json
clustermesh/endpoints/upsert firefly/10.245.8.31 endpoint-firefly-cougar-1.json
clustermesh/endpoints/upsert firefly/10.245.8.32 endpoint-firefly-lion-1.json
clustermesh/endpoints/sync

# Assert that the mapentries table got properly reconciled. The only external
# endpoint present should be the one advertised by the local node.
# L2 announcements should not be enabled for any entry at this point.
db/cmp privnet-mapentries mapentries.v1.table

# Activate a few networks, and check that L2 announcements are correctly updated.
checkerpool/activate cougar default/foobar-worker-1 maggot
checkerpool/activate lion   default/foobar-worker-1 firefly
db/cmp privnet-mapentries mapentries.v2.table

# Deregister one of the networks, and check that L2 announcements are correctly updated.
checkerpool/deactivate cougar default/foobar-worker-1 maggot
db/cmp privnet-mapentries mapentries.v3.table

# Register it again, and check that L2 announcements are correctly updated.
checkerpool/activate cougar default/foobar-worker-1 maggot
db/cmp privnet-mapentries mapentries.v2.table

# Ingest a few more endpoints from clustermesh.
clustermesh/endpoints/upsert maggot/10.245.8.23 endpoint-maggot-cougar-3.json
clustermesh/endpoints/upsert firefly/10.245.8.33 endpoint-firefly-lion-2.json

# L2 announcements should be set correctly.
db/cmp privnet-mapentries mapentries.v4.table

# Change registered networks once more, and check that L2 announcements are correct.
checkerpool/activate cougar default/foobar-worker-1 firefly
checkerpool/deactivate lion default/foobar-worker-1 firefly
db/cmp privnet-mapentries mapentries.v5.table

# Stop serving one of the networks, L2 announcements should be reset.
db/insert devices device.eth1.v2.yaml
db/cmp privnet-mapentries mapentries.v6.table

-- device.eth1.yaml --
index: 10
name: eth1
type: veth
selected: true

-- device.eth1.v2.yaml --
index: 10
name: eth1
type: veth
selected: false
notselectedreason: not matching user filter

-- device.eth2.yaml --
index: 11
name: eth2
type: veth
selected: true

-- icpn-1.yaml --
apiVersion: isovalent.com/v1alpha1
kind: ClusterwidePrivateNetwork
metadata:
  name: maggot
spec:
  interface:
    name: eth1
  routes: []
  subnets:
  - cidr: 192.168.250.0/24

-- icpn-2.yaml --
apiVersion: isovalent.com/v1alpha1
kind: ClusterwidePrivateNetwork
metadata:
  name: firefly
spec:
  interface:
    name: eth2
  routes: []
  subnets:
  - cidr: 192.168.251.0/24

-- local-workload-optimum-mouse.yaml --
endpointid: 11
namespace: foo
endpoint:
    addressing:
      ipv4: 10.245.8.20
    name: optimum-mouse
interface:
    addressing:
      ipv4: 192.168.250.20
    mac: 19:60:b8:48:84:20
    network: maggot
activatedat: 2025-06-20T12:40:00Z
flags:
    external: false

-- local-workload-shining-burro.yaml --
endpointid: 16
namespace: foo
endpoint:
    addressing:
      ipv4: 10.245.8.39
    name: shining-burro
interface:
    addressing:
      ipv4: 192.168.251.39
    mac: 19:60:b8:48:84:39
    network: firefly
activatedat: 2025-06-20T12:40:00Z
flags:
    external: true

-- privnet-eps.yaml --
apiVersion: isovalent.com/v1alpha1
kind: PrivateNetworkEndpointSlice
metadata:
  namespace: default
  name: privnet-eps-1
endpoints:
- activatedAt: "2025-06-20T15:54:04.765000Z"
  endpoint:
    addressing:
      ipv4: 10.245.8.30
    name: moved-racer
  interface:
    addressing:
      ipv4: 192.168.251.30
    mac: 19:60:b8:48:84:30
    network: firefly
- activatedAt: "2025-06-20T15:54:03.234000Z"
  endpoint:
    addressing:
      ipv4: 10.245.8.39
    name: destined-bluejay
  flags:
    external: true
  interface:
    addressing:
      ipv4: 192.168.251.39
    mac: 19:60:b8:48:84:39
    network: maggot
nodeName: foobar-worker-2

