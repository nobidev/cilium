-- privnet-epslice-1.yaml --
apiVersion: isovalent.com/v1alpha1
kind: PrivateNetworkEndpointSlice
metadata:
  namespace: keen-calf
  name: slice-1
endpoints:
- activatedAt: "2025-06-20T15:54:04.501000Z"
  endpoint:
    addressing:
      ipv4: 10.244.5.108
      ipv6: fd00:10:244:5::108
    name: optimum-mouse
  interface:
    addressing:
      ipv4: 10.0.100.40
      ipv6: fd00:10:100::40
    mac: 00:50:56:ad:45:ec
    network: blue-network
- activatedAt: "2025-06-20T16:29:49.321000Z"
  endpoint:
    addressing:
      ipv4: 10.244.5.63
      ipv6: fd00:10:244:5::63
    name: pumped-ocelot
  interface:
    addressing:
      ipv4: 10.0.100.52
      ipv6: fd00:10:100::52
    mac: 00:50:56:ad:45:d8
    network: green-network
- endpoint:
    addressing:
      ipv4: 10.244.5.109
      ipv6: fd00:10:244:5::109
    name: regular-koi
  interface:
    addressing:
      ipv4: 10.0.100.52
      ipv6: fd00:10:100::52
    mac: 00:50:56:ad:11:99
    network: blue-network
nodeName: cricket

