-- privnet-epslice-2.v2.yaml --
apiVersion: isovalent.com/v1alpha1
kind: PrivateNetworkEndpointSlice
metadata:
  namespace: keen-calf
  name: slice-2
endpoints:
- activatedAt: "2025-06-20T15:54:04.501000Z"
  endpoint:
    addressing:
      ipv4: 10.244.5.108
      ipv6: fd00:10:244:5::108
    name: optimum-mouse
  interface:
    addressing:
      ipv4: 10.0.100.40
      ipv6: fd00:10:100::40
    mac: 00:50:56:ad:45:ec
    network: blue-segment
- activatedAt: "2025-06-20T16:24:09.627000Z"
  endpoint:
    addressing:
      ipv4: 10.244.7.42
    name: enabling-lacewing
  interface:
    addressing:
      ipv4: 10.0.100.50
    mac: 00:50:56:ad:9b:c7
    network: yellow-segment


