#! --cluster-name=local --private-networks-enabled

hive start

# Add one PrivateNetworkEndpointSlice and ensure that the table is correct.
k8s/add privnet-epslice-1.yaml
k8s/add icpn-blue.yaml icpn-green.yaml icpn-yellow.yaml

# Ensure that the entries are correctly propagated into the table
db/cmp privnet-endpoints endpoints.v1.table

# Observe endpoints from clustermesh, and assert that the entries are propagated
clustermesh/endpoints/upsert blue-network/10.245.5.77 clustermesh-entry-1.json
clustermesh/endpoints/upsert blue-network/10.245.5.78 clustermesh-entry-2.json
clustermesh/endpoints/sync

db/cmp privnet-endpoints endpoints.v1+cm.table

# The table should be marked as initialized at this point
db/initialized privnet-endpoints

# Add two more PrivateNetworkEndpointSlices
cp privnet-epslice-2.yaml privnet-epslice-2.other-ns.yaml
replace 'keen-calf' 'selected-mako' privnet-epslice-2.other-ns.yaml
k8s/add privnet-epslice-2.yaml privnet-epslice-2.other-ns.yaml

# Ensure that the entries are correctly propagated into the table
db/cmp privnet-endpoints endpoints.v2.table

# Modify one PrivateNetworkEndpointSlice, and ensure that the table is updated.
k8s/update privnet-epslice-2.v2.yaml
db/cmp privnet-endpoints endpoints.v3.table

# More updates and deletions, and ensure that the table is updated.
k8s/update privnet-epslice-2.yaml
k8s/delete privnet-epslice-1.yaml privnet-epslice-2.other-ns.yaml

cp clustermesh-entry-1.json clustermesh-entry-1.v2.json
replace 'optimum-mouse' 'ethical-marmot' clustermesh-entry-1.v2.json
clustermesh/endpoints/upsert blue-network/10.245.5.77 clustermesh-entry-1.v2.json
clustermesh/endpoints/delete blue-network/10.245.5.78 clustermesh-entry-2.json

db/cmp privnet-endpoints endpoints.v4.table

# Re-add ep slice
k8s/add privnet-epslice-1.yaml privnet-epslice-2.other-ns.yaml
k8s/update privnet-epslice-2.v2.yaml
db/cmp privnet-endpoints endpoints.v5.table

# Delete green-network / split blue network
k8s/delete icpn-green.yaml
k8s/update icpn-blue.yaml.v2
db/cmp privnet-endpoints endpoints.v6.table

# remerge blue network
k8s/update icpn-blue.yaml
db/cmp privnet-endpoints endpoints.v7.table

# Add eps that don't match subnet - should not be assigned to subnet
k8s/update privnet-epslice-2.v3.yaml
clustermesh/endpoints/upsert blue-network/10.245.3.71 clustermesh-entry-3.json
clustermesh/endpoints/upsert blue-network/fd00:10:244:6::18 clustermesh-entry-4.json
db/cmp privnet-endpoints endpoints.v8.table

# Delete conflicting clustermesh entry - other ep should be assigned to subnet
clustermesh/endpoints/delete blue-network/fd00:10:244:6::18 clustermesh-entry-4.json
db/cmp privnet-endpoints endpoints.v9.table

# Add back clustermesh entry with correct IP - should be assigned to subnet
# Add new blue subnets - random-pumpkin is in two networks
clustermesh/endpoints/upsert blue-network/fd00:10:244:6::18 clustermesh-entry-4.json.v2
k8s/update icpn-blue.yaml.v3
db/cmp privnet-endpoints endpoints.v10.table

# ---

-- icpn-blue.yaml --
apiVersion: isovalent.com/v1alpha1
kind: ClusterwidePrivateNetwork
metadata:
  name: blue-network
spec:
  subnets:
  - name: blue1
    cidrv4: 10.0.100.0/24
    cidrv6: fd00:10:100::0/64

-- icpn-blue.yaml.v2 --
