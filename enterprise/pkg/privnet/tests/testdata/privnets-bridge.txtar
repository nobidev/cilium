    index: 10
    error: ""
    conflict: false
subnets:
    - name: foo
      cidrv4: 192.168.250.0/24
      cidrv6: ""
      routes: []
---
name: united-firefly
id: 2
vni: null
inbs:
    selectors: {}
interface:
    name: eth2
    index: 0
    error: Interface "eth2" has "lower-layer-down" operational status
    conflict: false
subnets:
    - name: bar
      cidrv4: 192.168.251.0/24
      cidrv6: ""
      routes: []
