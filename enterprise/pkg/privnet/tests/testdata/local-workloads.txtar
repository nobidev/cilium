-- pod-speedy-cheetah.v1.yaml --
apiVersion: v1
kind: Pod
metadata:
  name: speedy-cheetah
  namespace: bar
  annotations:
    network.v1alpha1.isovalent.com/inactive: "true"
    network.v1alpha1.isovalent.com/network-attachment: '{"network":"green-network","ipv4":"10.20.0.11","ipv6":"fd00:10:244:5::116","mac":"00:50:56:ad:11:02"}'
spec:
  containers:
  - name: sleep
    image: busybox
    command: ["sleep", "3600"]
  nodeName: foobar-worker-1
