#! --private-networks-enabled

# Restore endpoint
privnet/epm-restore ep-curious-koala.json
db/cmp privnet-local-workloads local-workloads.v1.table

# Ensure the table is not initialized before restoration finishes
! db/initialized --timeout 0 privnet-local-workloads

# Start hive (this will also finish restoration)
hive start
clustermesh/endpoints/sync
db/initialized

# Create three endpoints - clever-fox is a regular endpoint without privnet
privnet/epm-create ep-speedy-cheetah.json
privnet/epm-create ep-sleepy-sloth.json
privnet/epm-create ep-clever-fox.json
db/cmp privnet-local-workloads local-workloads.v2.table

# Mark speedy-cheetah as inactive via pod annotation
k8s/add pod-speedy-cheetah.v1.yaml

# Remove curious-koala
privnet/epm-delete foo/curious-koala

# Assert that both changes are visible in the table
db/cmp privnet-local-workloads local-workloads.v3.table

-- local-workloads.v1.table --
Endpoint             ID   Network         NetworkIPv4     NetworkIPv6           PodIPv4        PodIPv6              ActivatedAt
foo/curious-koala    15   green-network   10.20.0.10      fd00:10:20::10        10.244.5.115   fd00:10:244:5::115   2025-09-17T12:40:00Z

-- local-workloads.v2.table --
Endpoint             ID   Network         NetworkIPv4     NetworkIPv6           PodIPv4        PodIPv6              ActivatedAt
foo/curious-koala    15   green-network   10.20.0.10      fd00:10:20::10        10.244.5.115   fd00:10:244:5::115   2025-09-17T12:40:00Z
bar/speedy-cheetah   16   green-network   10.20.0.11      fd00:10:20::11        10.244.5.116   fd00:10:244:5::116   2025-09-17T12:41:00Z
qux/sleepy-sloth     17   blue-network    192.168.30.10   fd00:192:168:30::10   10.244.5.117   fd00:10:244:5::117   2025-09-17T12:42:00Z

-- local-workloads.v3.table --
Endpoint             ID   Network         NetworkIPv4     NetworkIPv6           PodIPv4        PodIPv6              ActivatedAt
bar/speedy-cheetah   16   green-network   10.20.0.11      fd00:10:20::11        10.244.5.116   fd00:10:244:5::116   <inactive>
qux/sleepy-sloth     17   blue-network    192.168.30.10   fd00:192:168:30::10   10.244.5.117   fd00:10:244:5::117   2025-09-17T12:42:00Z

