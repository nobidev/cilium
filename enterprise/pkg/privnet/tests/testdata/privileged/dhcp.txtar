#! --private-networks-enabled
#
# Test the DHCP server functionality with a static relay.
# We create "cilium_dhcp" as a veth-backed DHCP interface and use the peer
# socket via the 'dhcp/exchange' command.
#

# This tests needs to run privileged to set up a network namespace
[!privileged] stop

# Create the cilium_dhcp test interface and add a workload.
dhcp/link-new cilium_dhcp
dhcp/set-endpoint-ifindex cilium_dhcp endpoint-100.json
privnet/epm-create endpoint-100.json
k8s/add icpn.yaml

# Start the test application
hive/start

# Endpoint slice should exist but has 0.0.0.0 as address as DHCP exchange has not been done yet.
* k8s/get isovalent.com.v1alpha1.privatenetworkendpointslices default/foobar-worker-1 -o endpointslices.before.yaml
grep 'pod-100' endpointslices.before.yaml
grep 'ipv4: 0.0.0.0' endpointslices.before.yaml

# Endpoint table should not contain this endpoint before DHCP lease allocation.
db/empty privnet-endpoints

# Workload doesn't have IP assigned.
db/cmp privnet-local-workloads local-workloads.before.table

# Perform the DHCP exchange
* dhcp/exchange 100

# Check that endpoint slices was updated
* k8s/get isovalent.com.v1alpha1.privatenetworkendpointslices default/foobar-worker-1 -o endpointslices.actual.yaml
sed 'resourceVersion: ".*"' 'resourceVersion: "<nr>"' endpointslices.actual.yaml
* cmp endpointslices.expected.yaml endpointslices.actual.yaml

# Validate that DHCP lease table has updated and the LocalWorkload has been assigned an IP
# and that we've done a round-trip via the endpoint slices into the endpoints table.
db/cmp privnet-dhcp-leases dhcp-leases.table
db/cmp privnet-local-workloads local-workloads.table
db/cmp privnet-endpoints endpoints.table
db/cmp privnet-device-mappings devmappings.table

# Force lease expiration and ensure LocalWorkload is cleared
db/insert privnet-dhcp-leases dhcp-lease-expired.yaml
db/cmp privnet-local-workloads local-workloads.before.table
db/cmp privnet-device-mappings devmappings.expired.table
db/empty privnet-dhcp-leases

# Check that endpoint slice has retracted the leased IPv4 after expiry.
* k8s/get isovalent.com.v1alpha1.privatenetworkendpointslices default/foobar-worker-1 -o endpointslices.expired.yaml
grep 'pod-100' endpointslices.expired.yaml
! grep 'ipv4: 192.168.100.10' endpointslices.expired.yaml

# Perform the DHCP exchange again to populate leases.
* dhcp/exchange 100
db/cmp privnet-dhcp-leases dhcp-leases.table

# Restart hive to test recovery from WAL
hive/stop
hive/recreate
hive/start

db/cmp privnet-dhcp-leases dhcp-leases.table

# ---

-- local-workloads.before.table --
Endpoint          ID   Network        NetworkIPv4   PodIPv4
default/pod-100   100  blue-network   0.0.0.0       10.244.5.112

-- local-workloads.table --
Endpoint          ID   Network        NetworkIPv4     PodIPv4  
default/pod-100   100  blue-network   192.168.100.10  10.244.5.112

-- endpoints.table --
Source                            Name      Network        Subnet    NetworkIP        NetworkMAC          PodIP
default/default/foobar-worker-1   pod-100   blue-network   subnet1   192.168.100.10   02:00:00:00:00:01   10.244.5.112

-- devmappings.table --
Network        NetworkID   NetworkIPv4     Owner
blue-network   0x1         192.168.100.10  lw-100

-- devmappings.expired.table --
Network        NetworkID   NetworkIPv4     Owner
blue-network   0x1         0.0.0.0         lw-100

-- dhcp-leases.table --
Network        EndpointID   MAC                 IPv4            ServerID
blue-network   100          02:00:00:00:00:01   192.168.100.10  192.168.100.1

-- dhcp-leases.expired.table --
Network        EndpointID   MAC                 IPv4            ServerID        RenewAt                 ExpireAt
blue-network   100          02:00:00:00:00:01   192.168.100.10  192.168.100.1   2025-01-01T00:00:00Z    2025-01-01T00:00:01Z

-- endpointslices.expected.yaml --
apiVersion: isovalent.com/v1alpha1
endpoints:
- activatedAt: "2025-06-20T15:58:07.000000Z"
  endpoint:
    addressing:
      ipv4: 10.244.5.112
      ipv6: fd00:10:244:5::112
    name: pod-100
  flags:
    external: true
  interface:
    addressing:
      ipv4: 192.168.100.10
    mac: "02:00:00:00:00:01"
    network: blue-network
kind: PrivateNetworkEndpointSlice
metadata:
  name: foobar-worker-1
  namespace: default
  ownerReferences:
  - apiVersion: cilium.io/v2
    kind: CiliumNode
    name: foobar-worker-1
    uid: a354cce5-e6dc-4cb1-8125-a3a1bf93fd8a
  resourceVersion: "<nr>"
nodeName: foobar-worker-1
-- dhcp-lease-expired.yaml --
network: blue-network
endpointid: 100
mac: "02:00:00:00:00:01"
ipv4: 192.168.100.10
serverid: 192.168.100.1
obtainedat: 2025-01-01T00:00:00Z
renewat: 2025-01-01T00:00:00Z
expireat: 2025-01-01T00:00:01Z

-- endpoint-100.json --
{
  "ID": 100,
  "addressing": {
    "ipv4": "10.244.5.112",
    "ipv6": "fd00:10:244:5::112"
  },
  "mac": "02:00:00:00:00:01",
  "k8s-pod-name": "pod-100",
  "k8s-namespace": "default",
  "properties": {
    "property-fake-endpoint": true,
    "isovalent-privnet-activated-at": "2025-06-20T15:58:07.00000Z",
    "isovalent-privnet-network": "blue-network",
    "isovalent-privnet-subnet": "subnet1",
    "isovalent-privnet-ipv4-addr": "0.0.0.0"
  }
}

-- icpn.yaml --
apiVersion: isovalent.com/v1alpha1
kind: ClusterwidePrivateNetwork
metadata:
  name: blue-network
spec:
  routes: []
  subnets:
  - name: subnet1
    cidrv4: 192.168.100.0/24
    dhcp:
      mode: broadcast
