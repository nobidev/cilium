#! --private-networks-enabled

# Setup pre-restoration state:
#  - namespace foo: Orphaned endpoint slice (should be deleted by prune)
#  - namespace bar: Outdated endpoint slice (should be updated by prune)
#  - namespace qux: Missing endpoint slice  (should be created by prune)

k8s/add icpn-red.v1.yaml
k8s/add privnet-eps-foo.v1.yaml
k8s/add privnet-eps-bar.v1.yaml

privnet/epm-create ep-hopeful-wombat.json   # in bar
privnet/epm-create ep-competent-dophin.json # in bar
privnet/epm-create ep-awesome-gnu.json      # in qux

hive start
clustermesh/endpoints/sync
clustermesh/nodes/sync
db/initialized

# Ensure slice in foo is deleted
!* k8s/get isovalent.com.v1alpha1.privatenetworkendpointslices foo/foobar-worker-1

# Ensure slice in bar is updated
* k8s/get isovalent.com.v1alpha1.privatenetworkendpointslices bar/foobar-worker-1 -o privnet-eps-bar.actual.v2.yaml
sed 'resourceVersion: ".*"' 'resourceVersion: "<nr>"' privnet-eps-bar.actual.v2.yaml
* cmp privnet-eps-bar.expected.v2.yaml privnet-eps-bar.actual.v2.yaml

# Ensure slice in qux is created
* k8s/get isovalent.com.v1alpha1.privatenetworkendpointslices qux/foobar-worker-1 -o privnet-eps-qux.actual.v2.yaml
sed 'resourceVersion: ".*"' 'resourceVersion: "<nr>"' privnet-eps-qux.actual.v2.yaml
* cmp privnet-eps-qux.expected.v2.yaml privnet-eps-qux.actual.v2.yaml

# Wait for reconciler to reach steady state
db/show privnet-local-endpointslices  -o local-endpointslices.actual.v2.table
sed 'Done (.*)' 'Done (<time>)' local-endpointslices.actual.v2.table
* cmp local-endpointslices.expected.v2.table local-endpointslices.actual.v2.table

# Add endpoint in qux
privnet/epm-create ep-reverent-chicken.json # in qux

# Wait for updated qux slice
k8s/get isovalent.com.v1alpha1.privatenetworkendpointslices qux/foobar-worker-1 -o privnet-eps-qux.actual.v3.yaml
sed 'resourceVersion: ".*"' 'resourceVersion: "<nr>"' privnet-eps-qux.actual.v3.yaml
* cmp privnet-eps-qux.expected.v3.yaml privnet-eps-qux.actual.v3.yaml

# Delete endpoint in bar,
privnet/epm-delete bar/hopeful-wombat

# Wait for updated bar slice
k8s/get isovalent.com.v1alpha1.privatenetworkendpointslices bar/foobar-worker-1 -o privnet-eps-bar.actual.v3.yaml
sed 'resourceVersion: ".*"' 'resourceVersion: "<nr>"' privnet-eps-bar.actual.v3.yaml
* cmp privnet-eps-bar.expected.v3.yaml privnet-eps-bar.actual.v3.yaml

# Modify bar slice (malicious update to stale version)
k8s/add privnet-eps-bar.v1.yaml

# Wait for the reconciler to restore correct version
k8s/get isovalent.com.v1alpha1.privatenetworkendpointslices bar/foobar-worker-1 -o privnet-eps-bar.actual.v3.yaml
sed 'resourceVersion: ".*"' 'resourceVersion: "<nr>"' privnet-eps-bar.actual.v3.yaml
* cmp privnet-eps-bar.expected.v3.yaml privnet-eps-bar.actual.v3.yaml

# Delete last endpoint in bar
privnet/epm-delete bar/competent-dophin

# Wait for removed bar slice
!* k8s/get isovalent.com.v1alpha1.privatenetworkendpointslices bar/foobar-worker-1

# Delete qux slice (malicious update)
k8s/delete privnet-eps-qux.actual.v3.yaml

# Wait for the reconciler to restore correct version
* k8s/get isovalent.com.v1alpha1.privatenetworkendpointslices qux/foobar-worker-1 -o privnet-eps-qux.actual.v3.yaml
sed 'resourceVersion: ".*"' 'resourceVersion: "<nr>"' privnet-eps-qux.actual.v3.yaml
* cmp privnet-eps-qux.expected.v3.yaml privnet-eps-qux.actual.v3.yaml

-- icpn-red.v1.yaml --
apiVersion: isovalent.com/v1alpha1
kind: ClusterwidePrivateNetwork
metadata:
  name: red-network
spec:
  networkBridges:
  - ip: 172.128.0.6
  routes: []
  subnets:
  - cidr: 10.0.100.0/24
  - cidr: fd00:10:100::0/64

-- privnet-eps-foo.v1.yaml --
apiVersion: isovalent.com/v1alpha1
endpoints:
- activatedAt: "2025-06-20T15:54:04.501000Z"
  endpoint:
    addressing:
      ipv4: 10.244.5.108
      ipv6: fd00:10:244:5::108
    name: hungry-raven
  flags: {}
  interface:
    addressing:
      ipv4: 10.0.100.8
      ipv6: fd00:10:100::8
    mac: 00:50:56:ad:45:ec
    network: red-network
kind: PrivateNetworkEndpointSlice
metadata:
  name: foobar-worker-1
  namespace: foo
  ownerReferences:
  - apiVersion: cilium.io/v2
    kind: CiliumNode
    name: foobar-worker-1
    uid: a354cce5-e6dc-4cb1-8125-a3a1bf93fd8a
nodeName: foobar-worker-1
