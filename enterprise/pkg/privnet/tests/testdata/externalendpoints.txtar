    name: noble-wolf
  name: noble-wolf
  namespace: forest
  uid: 68adabc2-7878-4ab5-83d2-be5515d07fb9
spec:
  inactive: true
  interface:
    network: green
    addressing:
      ipv4: "10.0.100.9"
      ipv6: "fd00:10:100::9"
    mac: "00:50:56:ad:11:99"
status:
  activatedAt: "2025-01-01T10:20:30.000000Z"

