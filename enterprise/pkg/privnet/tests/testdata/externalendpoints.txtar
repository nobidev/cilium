#! --private-networks-enabled --private-networks-mode=bridge --cluster-name=cluster3

# Create sky namespace
k8s/add ns-forest.v1.yaml

# Create private networks
k8s/add icpn-blue.v1.yaml
k8s/add icpn-green.v1.yaml

# Create two endpoints (dashing-raven has no namespace metadata yet)
k8s/add dashing-raven.v1.yaml
k8s/add noble-wolf.v1.yaml

# Prepare IPAM allocator
privnet/ipam-reserve 'forest/noble-wolf [restored]'     10.244.5.111 fd00:10:244:5::111
privnet/ipam-reserve 'forest/stale-snail [restored]'    10.244.5.112 fd00:10:244:5::112
privnet/ipam-reserve 'sky/dashing-raven'                10.244.5.113 fd00:10:244:5::113
privnet/ipam-reserve 'forest/noble-wolf'                10.244.5.114 fd00:10:244:5::114

# Endpoint restoration (one stale endpoint restored)
privnet/epm-restore ep-noble-wolf.v1.json
privnet/epm-restore ep-stale-snail.v1.json

# Sanity check that the stale endpoint does not exist
# (we execute the exact same command below, but expect it to fail then)
privnet/epm-get --by cep-name forest/stale-snail

# Start hive
hive start
clustermesh/endpoints/sync
clustermesh/nodes/sync

# Check external endpoint policy map
privnet/maps-dump ext_eps_policy ext-eps-policy.v1.actual.map
* cmp ext-eps-policy.v1.expected.map ext-eps-policy.v1.actual.map

# Finish regeneration, this should prune stale-snail
privnet/epm-finish-regeneration
db/initialized

# Wait for K8s reconciler to be done
db/show privnet-external-endpoints --columns Name,Network,NetworkIPv4,NetworkIPv6,MAC,ActivatedAt,K8sStatus -o externalendpoints.actual.v1.table
sed 'Done \([^)]+\)' 'Done (<time>)' externalendpoints.actual.v1.table
* cmp externalendpoints.expected.v1.table externalendpoints.actual.v1.table

# Assert no change in status of dashing-raven
k8s/get isovalent.com.v1alpha1.privatenetworkexternalendpoints sky/dashing-raven -o dashing-raven.v1.actual.yaml
sed 'resourceVersion: ".*"' 'resourceVersion: "<nr>"' dashing-raven.v1.actual.yaml
cmp dashing-raven.v1.expected.yaml dashing-raven.v1.actual.yaml

# Assert status field of noble-wolf is cleared
k8s/get isovalent.com.v1alpha1.privatenetworkexternalendpoints forest/noble-wolf -o noble-wolf.v1.actual.yaml
sed 'resourceVersion: ".*"' 'resourceVersion: "<nr>"' noble-wolf.v1.actual.yaml
cmp noble-wolf.v1.expected.yaml noble-wolf.v1.actual.yaml

# Assert labels of noble-wolf
db/get privnet-external-endpoints forest/noble-wolf --format json -o noble-wolf.v1.actual.json
jsonpath noble-wolf.v1.actual.json '{.K8sLabels}{.K8sNamespaceLabels}' -o noble-wolf-labels.v1.actual.json
* cmp noble-wolf-labels.v1.expected.json noble-wolf-labels.v1.actual.json

# Assert noble-wolf is inactive (we assert against the same output again later)
db/get privnet-external-endpoints forest/noble-wolf --columns Name,ActivatedAt -o noble-wolf.v1.actual.table
cmp noble-wolf.v1.expected.table noble-wolf.v1.actual.table

# Wait for external endpoint reconciler to settle
db/show privnet-external-endpoints --columns Name,EndpointsStatus -o externalendpoints-eps-status.actual.v1.table
sed 'Done \([^)]+\)' 'Done (<time>)' externalendpoints-eps-status.actual.v1.table
* cmp externalendpoints-eps-status.expected.v1.table externalendpoints-eps-status.actual.v1.table

# Check that the stale-snail endpoint has been pruned
!* privnet/epm-get --by cep-name forest/stale-snail
# Check that the endpoint without namespace has not yet been created
! privnet/epm-get --by cep-name sky/dashing-raven
# Check that the restored endpoint has been updated (properties and labels)
privnet/epm-get --by cep-name forest/noble-wolf -o ep-noble-wolf.v1.actual.json
cmp ep-noble-wolf.v1.expected.json ep-noble-wolf.v1.actual.json

# Update labels and activate endpoint of noble-wolf
k8s/add noble-wolf.v2.yaml
k8s/add ns-forest.v2.yaml

# Wait for labels to be updated
db/get privnet-external-endpoints forest/noble-wolf --format json -o noble-wolf.v2.actual.json
jsonpath noble-wolf.v2.actual.json '{.K8sLabels}{.K8sNamespaceLabels}' -o noble-wolf-labels.v2.actual.json
* cmp noble-wolf-labels.v2.expected.json noble-wolf-labels.v2.actual.json

# Assert noble-wolf is active now (by checking that it is no longer inactive)
db/get privnet-external-endpoints forest/noble-wolf --columns Name,ActivatedAt -o noble-wolf.v2.actual.table
! cmp noble-wolf.v1.expected.table noble-wolf.v2.actual.table

# Create sky namespace, this should trigger the creation of the dashing-raven endpoint
k8s/add ns-sky.v3.yaml

# Wait for dashing-raven endpoint to be created
* privnet/epm-get --by cep-name sky/dashing-raven -o ep-dashing-raven.v3.actual.json
cmp ep-dashing-raven.v3.expected.json ep-dashing-raven.v3.actual.json

# Check external endpoint policy map
privnet/maps-dump ext_eps_policy ext-eps-policy.v2.actual.map
* cmp ext-eps-policy.v2.expected.map ext-eps-policy.v2.actual.map

# Re-create noble-wolf endpoint with a different UID and IP, and a static activatedAt time
k8s/add noble-wolf.v3.yaml

# Assert noble-wolf endpoint has been re-created
privnet/epm-get --by cep-name forest/noble-wolf -o ep-noble-wolf.v3.actual.json
* cmp ep-noble-wolf.v3.expected.json ep-noble-wolf.v3.actual.json

# Assert local workloads, endpoints and mapentries tables
db/cmp privnet-local-workloads local-workloads.expected.v3.table
db/cmp privnet-endpoints endpoints.expected.v3.table
db/cmp privnet-mapentries mapentries.expected.v3.table

# Check external endpoint policy map
privnet/maps-dump ext_eps_policy ext-eps-policy.v3.actual.map
* cmp ext-eps-policy.v3.expected.map ext-eps-policy.v3.actual.map

# Remove K8s resource
k8s/delete dashing-raven.v1.yaml
k8s/delete noble-wolf.v2.yaml

# Assert endpoints are removed
* db/empty privnet-external-endpoints
* db/empty privnet-local-workloads
!* privnet/epm-get --by cep-name forest/noble-wolf
!* privnet/epm-get --by cep-name sky/dashing-raven

# ---

#
# K8s manifests
#
-- icpn-blue.v1.yaml --
apiVersion: "isovalent.com/v1alpha1"
kind: ClusterwidePrivateNetwork
metadata:
  name: blue
spec:
  subnets:
    - name: subnet-blue-1
      cidrv4: 192.168.250.0/24
      cidrv6: fc00:0:250::0/96

-- icpn-green.v1.yaml --
apiVersion: isovalent.com/v1alpha1
kind: ClusterwidePrivateNetwork
metadata:
  name: green
spec:
  subnets:
    - name: subnet-green-1
      cidrv4: 10.0.100.0/24
      cidrv6: fd00:10:100::0/96

-- dashing-raven.v1.yaml --
apiVersion: isovalent.com/v1alpha1
kind: PrivateNetworkExternalEndpoint
metadata:
  labels:
    name: dashing-raven
  name: dashing-raven
  namespace: sky
  uid: 3868faa8-40c8-4813-ba35-87ecc1db55bf
spec:
  interface:
    network: blue
    addressing:
      ipv4: "192.168.250.42"
      ipv6: "fc00:0:250::42"
    mac: "ff:22:f1:22:21:51"
status:
  activatedAt: "2026-03-01T13:12:00.000000Z"

-- noble-wolf.v1.yaml --
