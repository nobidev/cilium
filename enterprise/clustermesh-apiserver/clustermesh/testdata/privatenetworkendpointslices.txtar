-- privnet-epslice-2.yaml --
apiVersion: isovalent.com/v1alpha1
kind: PrivateNetworkEndpointSlice
metadata:
  namespace: precise-caiman
  name: privnet-epslice-2
endpoints:
- activatedAt: "2025-06-20T16:13:01.667000Z"
  endpoint:
    addressing:
      ipv4: 10.244.6.80
    name: on-viper
  interface:
    addressing:
      ipv4: 10.0.100.43
    mac: 00:50:56:ad:45:ec
    network: blue-network

-- privnet-epslice-3.yaml --
