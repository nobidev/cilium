#! --cluster-id=3 --cluster-name=cluster3 --private-networks-enabled=true

hive/start

# Add two PrivateNetworkEndpointSlices
k8s/add privnet-epslice-1.yaml privnet-epslice-2.yaml

# Assert that the synced key gets created. We compare on the key only as the
# value is the timestamp at which synchronization completed
kvstore/list -o plain cilium/synced synced.actual
* grep -q '^# cilium/synced/cluster3/cilium/state/privneteps/v1$' synced.actual

# Wait for synchronization
kvstore/list -o json cilium/state/privneteps entries-1+2.actual
* cmp entries-1+2.actual entries-1+2.expected

# Update one of the PrivateNetworkEndpointSlices
k8s/update privnet-epslice-1-v2.yaml

# Wait for synchronization
kvstore/list -o json cilium/state/privneteps entries-1+2-v2.actual
* cmp entries-1+2-v2.actual entries-1+2-v2.expected

# Add one more PrivateNetworkEndpointSlices
k8s/add privnet-epslice-3.yaml

# Wait for synchronization
kvstore/list -o json cilium/state/privneteps entries-1+2+3.actual
* cmp entries-1+2+3.actual entries-1+2+3.expected

# Delete one of the PrivateNetworkEndpointSlices
k8s/delete privnet-epslice-2.yaml

# Wait for synchronization
kvstore/list -o json cilium/state/privneteps entries-1+3.actual
* cmp entries-1+3.actual entries-1+3.expected

# ---

-- privnet-epslice-1.yaml --
apiVersion: isovalent.com/v1alpha1
kind: PrivateNetworkEndpointSlice
metadata:
  namespace: keen-calf
  name: privnet-epslice-1
endpoints:
- activatedAt: "2025-06-20T15:54:04.501000Z"
  endpoint:
    addressing:
      ipv4: 10.244.5.108
      ipv6: fd00:10:244:5::108
    name: optimum-mouse
  interface:
    addressing:
      ipv4: 10.0.100.40
      ipv6: fd00:10:100::40
    mac: 00:50:56:ad:45:ec
    network: blue-network
- activatedAt: "2025-06-20T16:29:49.321000Z"
  endpoint:
    addressing:
      ipv4: 10.244.5.63
      ipv6: fd00:10:244:5::63
    name: pumped-ocelot
  interface:
    addressing:
      ipv4: 10.0.100.52
      ipv6: fd00:10:100::52
    mac: 00:50:56:ad:45:d8
    network: green-network
- endpoint:
    addressing:
      ipv4: 10.244.5.109
      ipv6: fd00:10:244:5::109
    name: regular-koi
  interface:
    addressing:
      ipv4: 10.0.100.52
      ipv6: fd00:10:100::52
    mac: 00:50:56:ad:11:99
    network: blue-network

