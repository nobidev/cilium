#! --cluster-id=3 --cluster-name=cluster3

hive/start

# Create the namespace used during the test.
k8s/add namespace.yaml

# Add a global service, and the corresponding endpointslice.
k8s/add service-global.yaml endpointslice.yaml

# Wait for synchronization.
kvstore/list -o json cilium/state/services services.actual
* cmp services.actual services.v1.expected

# Convert the service to phantom.
k8s/update service-phantom.yaml

# Wait for synchronization.
kvstore/list -o json cilium/state/services services.actual
* cmp services.actual services.v2.expected

# Remove the LoadBalancer IPs from the phantom service.
k8s/update service-phantom-no-ips.yaml

# Wait for synchronization, the service should no longer be propagated.
kvstore/list -o json cilium/state/services services.actual
* empty services.actual

# Configure the LoadBalancer IPs again.
k8s/update service-phantom.yaml

# Wait for synchronization.
kvstore/list -o json cilium/state/services services.actual
* cmp services.actual services.v2.expected

# Set the phantom annotation to false.
cp service-phantom.yaml service-phantom-disabled.yaml
sed 'service.isovalent.com/phantom: "true"' 'service.isovalent.com/phantom: "false"' service-phantom-disabled.yaml
k8s/update service-phantom-disabled.yaml

# Wait for synchronization, the service should no longer be propagated.
kvstore/list -o json cilium/state/services services.actual
* empty services.actual

# ----

-- namespace.yaml --
apiVersion: v1
kind: Namespace
metadata:
  name: test

-- service-global.yaml --
apiVersion: v1
kind: Service
metadata:
  name: echo
  namespace: test
  annotations:
    service.cilium.io/global: "true"
spec:
  clusterIP: 10.96.50.104
  clusterIPs:
  - 10.96.50.104
  ports:
  - name: http
    port: 80
    protocol: TCP
    targetPort: 8080
  selector:
    name: echo
  type: ClusterIP

-- service-phantom.yaml --
apiVersion: v1
kind: Service
metadata:
  name: echo
  namespace: test
  annotations:
    service.isovalent.com/phantom: "true"
spec:
  clusterIP: 10.96.50.104
  clusterIPs:
  - 10.96.50.104
  ports:
  - name: http
    port: 80
    protocol: TCP
    targetPort: 8080
  selector:
    name: echo
  type: LoadBalancer
status:
  loadBalancer:
    ingress:
    - ip: 192.168.0.1
    - ip: 192.168.0.3
    - hostname: foo.bar.local

-- service-phantom-no-ips.yaml --
apiVersion: v1
kind: Service
metadata:
  name: echo
  namespace: test
  annotations:
    service.isovalent.com/phantom: "true"
spec:
  clusterIP: 10.96.50.104
  clusterIPs:
  - 10.96.50.104
  ports:
  - name: http
    port: 80
    protocol: TCP
    targetPort: 8080
  selector:
    name: echo
  type: LoadBalancer
status:
  loadBalancer:
    ingress:
    - hostname: foo.bar.local

-- endpointslice.yaml --
apiVersion: discovery.k8s.io/v1
kind: EndpointSlice
metadata:
  labels:
    kubernetes.io/service-name: echo
  name: echo-kvlm2
  namespace: test
addressType: IPv4
endpoints:
- addresses:
  - 10.244.1.1
  conditions:
    ready: true
    serving: true
    terminating: false
  nodeName: nodeport-worker
  zone: zone1
  hints:
    forZones:
    - name: zone1
ports:
- name: http
  port: 8080
  protocol: TCP

-- services.v1.expected --
# cilium/state/services/v1/cluster3/test/echo
{
  "cluster": "cluster3",
  "namespace": "test",
  "name": "echo",
  "frontends": {
    "10.96.50.104": {
      "http": {
        "Protocol": "TCP",
        "Port": 80
      }
    }
  },
  "backends": {
    "10.244.1.1": {
      "http": {
        "Protocol": "TCP",
        "Port": 8080
      }
    }
  },
  "zones": {
    "10.244.1.1": {
      "zone": "zone1",
      "forZones": [
        {
          "name": "zone1"
        }
      ]
    }
  },
  "labels": {},
  "selector": {
    "name": "echo"
  },
  "includeExternal": true,
  "shared": true,
  "clusterID": 3
}
-- services.v2.expected --
# cilium/state/services/v1/cluster3/test/echo
{
  "cluster": "cluster3",
  "namespace": "test",
  "name": "echo",
  "frontends": {
    "192.168.0.1": {
      "http": {
        "Protocol": "TCP",
        "Port": 80
      }
    },
    "192.168.0.3": {
      "http": {
        "Protocol": "TCP",
        "Port": 80
      }
    }
  },
  "backends": {
    "10.244.1.1": {
      "http": {
        "Protocol": "TCP",
        "Port": 8080
      }
    }
  },
  "zones": {
    "10.244.1.1": {
      "zone": "zone1",
      "forZones": [
        {
          "name": "zone1"
        }
      ]
    }
  },
  "labels": {},
  "selector": {
    "name": "echo"
  },
  "includeExternal": false,
  "shared": true,
  "clusterID": 3
}
