{
  "start_time": "%START_TIME%",
  "logger": "access",
  "type": "http",
  "protocol": "%PROTOCOL%",
  "http.req.method": "%REQ(:METHOD)%",
  "http.req.authority": "%REQ(:AUTHORITY)%",
  "http.req.path": "%REQ(X-ENVOY-ORIGINAL-PATH?:PATH)%",
  "http.req.x-forwarded-for": "%REQ(X-FORWARDED-FOR)%",
  "http.req.user-agent": "%REQ(USER-AGENT)%",
  "http.req.x-request-id": "%REQ(X-REQUEST-ID)%",
  "http.resp.code": "%RESPONSE_CODE%",
  "http.resp.code.details": "%RESPONSE_CODE_DETAILS%",
  "http.resp.x-envoy-upstream-service-time": "%RESP(X-ENVOY-UPSTREAM-SERVICE-TIME)%",
  "response.flags": "%RESPONSE_FLAGS%",
  "response.flags-long": "%RESPONSE_FLAGS_LONG%",
  "connection.termination-details": "%CONNECTION_TERMINATION_DETAILS%",
  "bytes.received": "%BYTES_RECEIVED%",
  "bytes.sent": "%BYTES_SENT%",
  "duration": "%DURATION%",
  "stream.id": "%STREAM_ID%",
  "downstream.connection-id": "%CONNECTION_ID%",
  "downstream.local-address": "%DOWNSTREAM_LOCAL_ADDRESS%",
  "downstream.direct-remote-address": "%DOWNSTREAM_DIRECT_REMOTE_ADDRESS%",
  "downstream.remote-address": "%DOWNSTREAM_REMOTE_ADDRESS%",
  "downstream.transport-failure-reason": "%DOWNSTREAM_TRANSPORT_FAILURE_REASON%",
  "downstream.tls.cipher": "%DOWNSTREAM_TLS_CIPHER%",
  "downstream.tls.version": "%DOWNSTREAM_TLS_VERSION%",
  "downstream.tls.session-id": "%DOWNSTREAM_TLS_SESSION_ID%",
  "upstream.connection-id": "%UPSTREAM_CONNECTION_ID%",
  "upstream.host": "%UPSTREAM_HOST%",
  "upstream.local-address": "%UPSTREAM_LOCAL_ADDRESS%",
  "upstream.remote-address": "%UPSTREAM_REMOTE_ADDRESS%",
  "upstream.transport-failure-reason": "%UPSTREAM_TRANSPORT_FAILURE_REASON%",
  "upstream.tls.cipher": "%UPSTREAM_TLS_CIPHER%",
  "upstream.tls.version": "%UPSTREAM_TLS_VERSION%",
  "upstream.tls.session-id": "%UPSTREAM_TLS_SESSION_ID%"
}
