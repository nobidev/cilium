-- vm-2-expected.yaml --
apiVersion: kubevirt.io/v1
kind: VirtualMachine
metadata:
  labels:
    plan: 2dabc5ef-f1b5-4e63-9534-a8a17c0c0adf
    vmID: trusting-newt-alpha
  name: trusting-newt
  namespace: spaniel
  uid: cc2a8419-636b-406e-af81-daecb1c34b02
spec:
  runStrategy: Always
  template:
    metadata:
      annotations:
        privnet.isovalent.com/network-attachment: |-
          {
            "network": "egret",
            "interface": "net-0",
            "subnet": "ewe",
            "ipv4": "192.168.1.100",
            "ipv6": "2001::1:1002",
            "mac": "00:11:22:33:44:55"
          }
        privnet.isovalent.com/secondary-network-attachments: |-
          [
            {
              "network": "egret",
              "interface": "net-1",
              "subnet": "parrot",
              "ipv4": "0.0.0.0",
              "ipv6": "2001::2:1002",
              "mac": "00:11:22:33:44:66"
            },
            {
              "network": "egret",
              "interface": "net-2",
              "subnet": "parrot",
              "ipv4": "0.0.0.0",
              "ipv6": "2001::3:1002",
              "mac": "00:11:22:33:44:77"
            },
            {
              "network": "bull",
              "interface": "net-4",
              "subnet": "cow",
              "ipv4": "192.168.5.100",
              "ipv6": "2001::5:1002",
              "mac": "00:11:22:33:44:99"
            }
          ]
      labels:
        app: trusting-newt
    spec:
      domain:
        devices:
          interfaces:
          - binding:
              name: privnet
            macAddress: "00:11:22:33:44:55"
            name: net-0
          - binding:
              name: privnet
            macAddress: 00:11:22:33:44:66
            name: net-1
          - binding:
              name: privnet
            macAddress: 00:11:22:33:44:77
            name: net-2
          - bridge: {}
            macAddress: 00:11:22:33:44:88
            name: net-3
          - binding:
              name: privnet
            macAddress: 00:11:22:33:44:99
            name: net-4
          - bridge: {}
            macAddress: "00:11:22:33:44:00"
            name: net-5
        resources: {}
      networks:
      - multus:
          default: true
          networkName: spaniel/egret-ewe
        name: net-0
      - multus:
          networkName: spaniel/egret-parrot
        name: net-1
      - multus:
          networkName: egret-parrot
        name: net-2
      - multus:
          networkName: default/external
        name: net-3
      - multus:
          networkName: default/bull-cow
        name: net-4
      - multus:
          networkName: default/bull-donkey
        name: net-5
status: {}
-- EOR --

