-- vm-1.yaml --
apiVersion: kubevirt.io/v1
kind: VirtualMachine
metadata:
  name: trusting-newt
  namespace: grouper
  uid: cc2a8419-636b-406e-af81-daecb1c34b02
spec:
  runStrategy: Always
  template:
    metadata:
      labels:
        app: trusting-newt
    spec:
      domain:
        devices:
          interfaces:
          - masquerade: {}
            macAddress: 00:11:22:33:44:55
            name: net-0
          - bridge: {}
            macAddress: 00:11:22:33:44:66
            name: net-1
      networks:
      - name: net-0
        pod: {}
      - multus:
          networkName: spaniel/nad-1
        name: net-1

-- vm-2.yaml --
apiVersion: kubevirt.io/v1
kind: VirtualMachine
metadata:
  name: trusting-newt
  namespace: spaniel
  uid: cc2a8419-636b-406e-af81-daecb1c34b02
  labels:
    plan: 2dabc5ef-f1b5-4e63-9534-a8a17c0c0adf
    vmID: trusting-newt-alpha
spec:
  runStrategy: Always
  template:
    metadata:
      labels:
        app: trusting-newt
    spec:
      domain:
        devices:
          interfaces:
          - bridge: {}
            macAddress: 00:11:22:33:44:55
            name: net-0
          - bridge: {}
            macAddress: 00:11:22:33:44:66
            name: net-1
          - bridge: {}
            macAddress: 00:11:22:33:44:77
            name: net-2
          - bridge: {}
            macAddress: 00:11:22:33:44:88
            name: net-3
          - masquerade: {}
            macAddress: 00:11:22:33:44:99
            name: net-4
          - bridge: {}
            macAddress: 00:11:22:33:44:00
            name: net-5
      networks:
      - multus:
          networkName: spaniel/egret-ewe
        name: net-0
      - multus:
          networkName: spaniel/egret-parrot
        name: net-1
      - multus:
          networkName: egret-parrot
        name: net-2
      - multus:
          networkName: default/external
        name: net-3
      - multus:
          networkName: default/bull-cow
        name: net-4
      - multus:
          networkName: default/bull-donkey
        name: net-5

-- vm-2-expected.yaml --
apiVersion: kubevirt.io/v1
kind: VirtualMachine
metadata:
  labels:
    plan: 2dabc5ef-f1b5-4e63-9534-a8a17c0c0adf
    vmID: trusting-newt-alpha
  name: trusting-newt
  namespace: spaniel
  uid: cc2a8419-636b-406e-af81-daecb1c34b02
spec:
  runStrategy: Always
  template:
    metadata:
      annotations:
        privnet.isovalent.com/network-attachment: |-
          {
            "network": "egret",
            "interface": "net-0",
            "subnet": "ewe"
          }
        privnet.isovalent.com/secondary-network-attachments: |-
          [
            {
              "network": "egret",
              "interface": "net-1",
              "subnet": "parrot"
            },
            {
              "network": "egret",
              "interface": "net-2",
              "subnet": "parrot"
            },
            {
              "network": "bull",
              "interface": "net-4",
              "subnet": "cow"
            }
          ]
      labels:
        app: trusting-newt
    spec:
      domain:
        devices:
          interfaces:
          - binding:
              name: privnet
            macAddress: "00:11:22:33:44:55"
            name: net-0
          - binding:
              name: privnet
            macAddress: 00:11:22:33:44:66
            name: net-1
          - binding:
              name: privnet
            macAddress: 00:11:22:33:44:77
            name: net-2
          - bridge: {}
            macAddress: 00:11:22:33:44:88
            name: net-3
          - binding:
              name: privnet
            macAddress: 00:11:22:33:44:99
            name: net-4
          - bridge: {}
            macAddress: "00:11:22:33:44:00"
            name: net-5
        resources: {}
      networks:
      - multus:
          default: true
          networkName: spaniel/egret-ewe
        name: net-0
      - multus:
          networkName: spaniel/egret-parrot
        name: net-1
      - multus:
          networkName: egret-parrot
        name: net-2
      - multus:
          networkName: default/external
        name: net-3
      - multus:
          networkName: default/bull-cow
        name: net-4
      - multus:
          networkName: default/bull-donkey
        name: net-5
status: {}
-- EOR --

