-- nads.table --
Namespace   Name             Type         Network       Subnet        Managed
default     bull-calf        cilium-cni   bull          calf          false
default     bull-cow         cilium-cni   bull          cow           false
default     bull-donkey      cilium-cni   __unknown__   __unknown__   false
default     external         external     N/A           N/A           false
default     other-calf       cilium-cni   other         calf          false
spaniel     egret-ewe        cilium-cni   egret         ewe           true
spaniel     egret-parrot     cilium-cni   egret         parrot        true
spaniel     egret-seahorse   cilium-cni   egret         seahorse      true

-- providers.table --
