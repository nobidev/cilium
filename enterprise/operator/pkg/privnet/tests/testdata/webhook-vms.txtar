#! --private-networks-enabled --private-networks-nad-integration-enabled --private-networks-webhook-enabled --private-networks-webhook-network-binding=privnet

# Create the ICPN and NAD CRDs to satisfy the existence check.
k8s/add icpn-crd.yaml nad-crd.yaml

hive/start

# Populate the Kubernetes objects, and wait for them to be observed.
k8s/add ns-1.yaml icpn-1.yaml icpn-2.yaml nad-1.yaml nad-2.yaml nad-3.yaml nad-4.yaml nad-5.yaml
db/cmp privnet-nads nads.table

# Populate the Forklift resources, and wait for them to be observed.
k8s/add provider-1.yaml provider-2.yaml
k8s/add plan-1.yaml plan-2.yaml plan-3.yaml

db/cmp privnet-forklift-providers providers.table
db/cmp privnet-forklift-plans plans.table

# A vanilla VM should not be mutated.
webhook/admit /virtualmachines/mutate create vm-1.yaml --expect-no-changes

# A migrated VM should be mutated as expected.
inventory/register-vm 5e497cae-e26e-40f3-b391-135b4cbbdd82 vm-2-inventory.json
webhook/admit /virtualmachines/mutate create vm-2.yaml -o vm-actual.yaml
cmp vm-actual.yaml vm-2-expected.yaml

# IPs should be also preserved for subnets with DHCP enabled, if requested.
cp vm-2.yaml vm-2-preserve-ips.yaml
replace 2dabc5ef-f1b5-4e63-9534-a8a17c0c0adf 532e2c42-f81b-4f6f-a797-c893ccefe3c5 vm-2-preserve-ips.yaml
webhook/admit /virtualmachines/mutate create vm-2-preserve-ips.yaml -o vm-actual.yaml
cmp vm-actual.yaml vm-2-preserve-ips-expected.yaml

# Update and delete operations should be ignored.
webhook/admit /virtualmachines/mutate update vm-2.yaml --expect-no-changes
webhook/admit /virtualmachines/mutate delete vm-2.yaml --expect-no-changes

# The pod network of a mutated VM should not be mangled with.
inventory/register-vm 5e497cae-e26e-40f3-b391-135b4cbbdd82 vm-3-inventory.json
webhook/admit /virtualmachines/mutate create vm-3.yaml -o vm-actual.yaml
cmp vm-actual.yaml vm-3-expected.yaml

# Expect an error if a migrated VM references a non-existing NAD.
cp vm-2.yaml vm-nad-not-existing.yaml
replace spaniel/egret-ewe something/else vm-nad-not-existing.yaml
! webhook/admit /virtualmachines/mutate create vm-nad-not-existing.yaml
cmp stderr err-nad-not-existing.txt

# Expect an error if a migrated VM references a NAD for an unknown network.
cp vm-2.yaml vm-net-not-existing.yaml
replace spaniel/egret-ewe default/other-calf vm-net-not-existing.yaml
! webhook/admit /virtualmachines/mutate create vm-net-not-existing.yaml
cmp stderr err-net-not-existing.txt

# Expect an error if a migrated VM references a NAD for an unknown subnet.
cp vm-2.yaml vm-subnet-not-existing.yaml
replace spaniel/egret-ewe default/bull-calf vm-subnet-not-existing.yaml
! webhook/admit /virtualmachines/mutate create vm-subnet-not-existing.yaml
cmp stderr err-subnet-not-existing.txt

# Expect an error if a migrated VM references an unknown plan.
cp vm-2.yaml vm-plan-not-existing.yaml
replace 2dabc5ef-f1b5-4e63-9534-a8a17c0c0adf not-existing vm-plan-not-existing.yaml
! webhook/admit /virtualmachines/mutate create vm-plan-not-existing.yaml --timeout=50ms
# We don't check the error, as it materializes as a timeout.

# Expect an error if a migrated VM references a source provider of unknown type.
cp vm-2.yaml vm-unknown-source-provider.yaml
replace 2dabc5ef-f1b5-4e63-9534-a8a17c0c0adf 84aed857-994a-4db0-804e-0add8a898204 vm-unknown-source-provider.yaml
! webhook/admit /virtualmachines/mutate create vm-unknown-source-provider.yaml
cmp stderr err-unknown-source-provider.txt

# Expect an error if a migrated VM references an unknown VM ID.
cp vm-2.yaml vm-unknown-vm-id.yaml
replace trusting-newt-alpha not-existing vm-unknown-vm-id.yaml
! webhook/admit /virtualmachines/mutate create vm-unknown-vm-id.yaml
cmp stderr err-unknown-vm-id.txt

# Expect an error if a migrated VM references an unknown interface in the inventory
cp vm-2.yaml vm-interface-not-found.yaml
replace 00:11:22:33:44:66 99:11:22:33:44:66 vm-interface-not-found.yaml
! webhook/admit /virtualmachines/mutate create vm-interface-not-found.yaml
cmp stderr err-interface-not-found.txt

# Expect an error if a migrated VM references an interface with unknown IPv4, with IP preservation.
cp vm-2-preserve-ips.yaml vm-interface-missing-ipv4.yaml
replace 00:11:22:33:44:66 00:11:22:33:66:66 vm-interface-missing-ipv4.yaml
! webhook/admit /virtualmachines/mutate create vm-interface-missing-ipv4.yaml
cmp stderr err-interface-missing-ipv4.txt

# Don't expect an error if a migrated VM references an interface with unknown IPv4, without IP preservation.
cp vm-2.yaml vm-interface-missing-ipv4.yaml
cp vm-2-expected.yaml vm-2-expected.v2.yaml
replace 00:11:22:33:44:66 00:11:22:33:66:66 vm-interface-missing-ipv4.yaml
replace 00:11:22:33:44:66 00:11:22:33:66:66 vm-2-expected.v2.yaml
webhook/admit /virtualmachines/mutate create vm-interface-missing-ipv4.yaml -o vm-actual.yaml
cmp vm-actual.yaml vm-2-expected.v2.yaml

# ---

-- icpn-crd.yaml --
apiVersion: apiextensions.k8s.io/v1
kind: CustomResourceDefinition
metadata:
  name: clusterwideprivatenetworks.isovalent.com
status:
  conditions:
  - type: "Established"
    status: "True"

-- nad-crd.yaml --
apiVersion: apiextensions.k8s.io/v1
kind: CustomResourceDefinition
metadata:
  name: network-attachment-definitions.k8s.cni.cncf.io

-- ns-1.yaml --
apiVersion: v1
kind: Namespace
metadata:
  name: spaniel
  labels:
    kubernetes.io/metadata.name: spaniel

-- icpn-1.yaml --
apiVersion: isovalent.com/v1alpha1
kind: ClusterwidePrivateNetwork
metadata:
  name: egret
spec:
  subnets:
  - name: parrot
    dhcp:
      mode: broadcast
  - name: ewe
  - name: seahorse
  networkAttachmentDefinitions:
    namespaceSelector:
      matchLabels:
        kubernetes.io/metadata.name: spaniel

-- icpn-2.yaml --
apiVersion: isovalent.com/v1alpha1
kind: ClusterwidePrivateNetwork
metadata:
  name: bull
spec:
  subnets:
  - name: cow

-- nad-1.yaml --
apiVersion: k8s.cni.cncf.io/v1
kind: NetworkAttachmentDefinition
metadata:
  name: external
  namespace: default
spec:
  config: '{"cniVersion": "0.3.1", "type": "external"}'

-- nad-2.yaml --
apiVersion: k8s.cni.cncf.io/v1
kind: NetworkAttachmentDefinition
metadata:
  name: bull-cow
  namespace: default
spec:
  config: '{"cniVersion": "0.3.1", "type": "cilium-cni",
    "private-networks": {"network": "bull", "subnet": "cow"}}'

-- nad-3.yaml --
apiVersion: k8s.cni.cncf.io/v1
kind: NetworkAttachmentDefinition
metadata:
  name: other-calf
  namespace: default
spec:
  config: '{"cniVersion": "0.3.1", "type": "cilium-cni",
    "private-networks": {"network": "other", "subnet": "calf"}}'

-- nad-4.yaml --
apiVersion: k8s.cni.cncf.io/v1
kind: NetworkAttachmentDefinition
metadata:
  name: bull-calf
  namespace: default
spec:
  config: '{"cniVersion": "0.3.1", "type": "cilium-cni",
    "private-networks": {"network": "bull", "subnet": "calf"}}'

-- nad-5.yaml --
apiVersion: k8s.cni.cncf.io/v1
kind: NetworkAttachmentDefinition
metadata:
  name: bull-donkey
  namespace: default
spec:
  config: '{"cniVersion": "0.3.1", "type": "cilium-cni"}'

