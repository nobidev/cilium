spec:
  runStrategy: Always
  template:
    metadata:
      annotations:
        privnet.isovalent.com/secondary-network-attachments: |-
          [
            {
              "network": "egret",
              "interface": "net-1",
              "subnet": "parrot",
              "ipv4": "0.0.0.0",
              "ipv6": "2001::2:1002",
              "mac": "00:11:22:33:44:66"
            }
          ]
      labels:
        app: trusting-newt
    spec:
      domain:
        devices:
          interfaces:
