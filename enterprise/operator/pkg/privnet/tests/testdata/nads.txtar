crow        sturgeon-starfish       sturgeon       starfish
default     egret-parrot            egret          parrot
default     egret-select-gull       egret          select-gull
default     winning-mallard         egret          ewe
spaniel     egret-ewe               egret          ewe
spaniel     egret-parrot            egret          parrot
spaniel     egret-select-gull       egret          select-gull
spaniel     sturgeon-longhorn       sturgeon       longhorn
spaniel     sturgeon-starfish       sturgeon       starfish

-- desired-nads.v2.table --
Namespace   Name                    Network        Subnet
default     egret-opossum           egret          opossum
default     egret-select-gull       egret          select-gull
default     winning-mallard         egret          ewe
spaniel     egret-ewe               egret          ewe
spaniel     egret-opossum           egret          opossum
spaniel     egret-select-gull       egret          select-gull
spaniel     egret-select-gull-n2r   egret-select   gull
spaniel     sturgeon-longhorn       sturgeon       longhorn
spaniel     sturgeon-starfish       sturgeon       starfish

-- desired-nads.v3.table --
Namespace   Name                    Network        Subnet
crow        sturgeon-longhorn       sturgeon       longhorn
crow        sturgeon-starfish       sturgeon       starfish
default     egret-opossum           egret          opossum
default     egret-select-gull       egret          select-gull
default     winning-mallard         egret          ewe
spaniel     egret-ewe               egret          ewe
spaniel     egret-opossum           egret          opossum
spaniel     egret-select-gull       egret          select-gull
spaniel     sturgeon-longhorn       sturgeon       longhorn
spaniel     sturgeon-starfish       sturgeon       starfish

-- desired-nads.v4.table --
Namespace   Name                    Network        Subnet
bluegill    egret-ewe               egret          ewe
