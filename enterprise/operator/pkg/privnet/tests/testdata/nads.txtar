#! --private-networks-enabled --private-networks-nad-integration-enabled

# Create the ICPN and NAD CRDs to satisfy the existence check. We do this before
# starting the hive to prevent unnecessary delay due to retries.
k8s/add icpn-crd.yaml nad-crd.yaml

# Initialize a few namespaces.
k8s/add ns-default.yaml ns-spaniel.yaml ns-crow.yaml

# Add a few network attachment definitions and private networks. We do this
# before starting the hive to validate the correct functioning of pruning.
k8s/add nad-1.yaml nad-2.yaml nad-3.yaml nad-4.yaml
k8s/add icpn-1.yaml icpn-2.yaml icpn-3.yaml

hive start
db/initialized private-networks privnet-nads privnet-desired-nads k8s-namespaces

# Assert that the set of desired NADs is populated correctly.
db/cmp privnet-desired-nads desired-nads.v1.table

# ... and assert that the created NADs are correct.
* k8s/get networkattachmentdefinitions crow/sturgeon-longhorn -o nad.actual.yaml
sed 'resourceVersion: ".*"' 'resourceVersion: "<nr>"' nad.actual.yaml
cmp nad-sturgeon-longhorn.expected.yaml nad.actual.yaml

# ... and assert that stale NADs are correctly pruned.
!* k8s/get networkattachmentdefinitions default/fast-oriole

# ... and assert that the created NADs are observed back.
db/cmp privnet-nads nads.v1.table

# Perform a few private network updates, and delete a user-managed NAD...
k8s/update icpn-1.v2.yaml icpn-2.v2.yaml icpn-3.v2.yaml
k8s/delete nad-1.yaml

# ... and assert that the set of desired NADs is updated correctly.
db/cmp privnet-desired-nads desired-nads.v2.table

# ... and assert that the deleted NADs have actually been deleted.
!* k8s/get networkattachmentdefinitions crow/sturgeon-longhorn

# ... and assert that the updated NADs are observed back.
db/cmp privnet-nads nads.v2.table

# Delete a private network, and update back another...
k8s/update icpn-2.yaml
k8s/delete icpn-3.v2.yaml

# ... and assert that the set of desired NADs is updated correctly
db/cmp privnet-desired-nads desired-nads.v3.table

# ... and assert that the updated NADs are observed back.
db/cmp privnet-nads nads.v3.table

# Create a namespace, update the labels of another, and delete yet another...
k8s/add ns-bluegill.yaml
k8s/update ns-default.v2.yaml
k8s/delete ns-spaniel.yaml

# ... and assert that the set of desired NADs is updated correctly
db/cmp privnet-desired-nads desired-nads.v4.table

# ... and assert that the updated NADs are observed back.
db/cmp privnet-nads nads.v4.table

# Manually update the NAD objects...
k8s/update nad-crow-sturgeon-longhorn.v2.yaml nad-crow-sturgeon-starfish.v2.yaml

# ... and validate that they are reconciled back, but only if managed by Cilium.
k8s/list networkattachmentdefinitions crow -o nads.actual.yaml
sed 'resourceVersion: ".*"' 'resourceVersion: "<nr>"' nads.actual.yaml
* cmp nads-crow.v2.expected.yaml nads.actual.yaml

# Manually delete a NAD object...
k8s/get networkattachmentdefinitions bluegill/egret-ewe -o nad-delete.yaml
k8s/delete nad-delete.yaml

# ... and validate that it is reconciled back.
* k8s/get networkattachmentdefinitions bluegill/egret-ewe

# ... and assert that the updated NADs are observed back.
db/cmp privnet-nads nads.v5.table

# ---

-- icpn-crd.yaml --
apiVersion: apiextensions.k8s.io/v1
kind: CustomResourceDefinition
metadata:
  name: clusterwideprivatenetworks.isovalent.com
status:
  conditions:
  - type: "Established"
    status: "True"

-- nad-crd.yaml --
apiVersion: apiextensions.k8s.io/v1
kind: CustomResourceDefinition
metadata:
  name: network-attachment-definitions.k8s.cni.cncf.io

-- nad-1.yaml --
apiVersion: k8s.cni.cncf.io/v1
kind: NetworkAttachmentDefinition
metadata:
  name: artistic-snapper
  namespace: crow
spec:
  config: '{"cniVersion": "0.3.1", "type": "foo", "enable-debug": "no-warning"}'

-- nad-2.yaml --
apiVersion: k8s.cni.cncf.io/v1
kind: NetworkAttachmentDefinition
metadata:
  name: winning-mallard
  namespace: default
  labels:
    app.kubernetes.io/managed-by: cilium
  annotations:
    foo: bar
spec:
  config: '{"cniVersion": "0.3.1", "type": "cilium-cni",
    "private-networks": {"network": "egret", "subnet": "ewe"}}'

-- nad-3.yaml --
apiVersion: k8s.cni.cncf.io/v1
kind: NetworkAttachmentDefinition
metadata:
  name: egret-parrot
  namespace: spaniel
spec:
  config: '{"cniVersion": "0.3.1", "type": "cilium-cni",
    "private-networks": {"network": "egret", "subnet": "parrot"}}'

-- nad-4.yaml --
apiVersion: k8s.cni.cncf.io/v1
kind: NetworkAttachmentDefinition
metadata:
  name: fast-oriole
  namespace: default
  labels:
    app.kubernetes.io/managed-by: cilium
spec:
  config: '{"cniVersion": "0.3.1", "type": "cilium-cni",
    "private-networks": {"network": "kindfish", "subnet": "duck"}}'

-- nad-sturgeon-longhorn.expected.yaml --
apiVersion: k8s.cni.cncf.io/v1
kind: NetworkAttachmentDefinition
metadata:
  labels:
    app.kubernetes.io/managed-by: cilium
  name: sturgeon-longhorn
  namespace: crow
  resourceVersion: "<nr>"
spec:
  config: '{"cniVersion": "0.3.1", "type": "cilium-cni", "enable-debug": false, "log-format":
    "text-ts", "log-file": "/var/run/cilium/cilium-cni.log", "private-networks": {"network":
    "sturgeon", "subnet": "longhorn"}}'
-- EOR --

-- nad-crow-sturgeon-longhorn.v2.yaml --
apiVersion: k8s.cni.cncf.io/v1
kind: NetworkAttachmentDefinition
metadata:
  name: sturgeon-longhorn
  namespace: crow
  annotations:
    foo: bar
  labels:
    app.kubernetes.io/managed-by: cilium
spec:
  config: '{"cniVersion": "0.3.1", "type": "cilium-cni", "enable-debug": false, "log-format":
    "foo", "log-file": "/var/run/cilium/cilium-cni.log", "private-networks": {"network":
    "sturgeon", "subnet": "baz"}}'

-- nad-crow-sturgeon-starfish.v2.yaml --
apiVersion: k8s.cni.cncf.io/v1
kind: NetworkAttachmentDefinition
metadata:
  name: sturgeon-starfish
  namespace: crow
  annotations:
    qux: baz
spec:
  config: '{"cniVersion": "0.3.1", "type": "cilium-cni", "enable-debug": false, "log-format":
    "text-ts","log-file": "/var/run/cilium/cilium-cni.log", "private-networks": {"network":
    "sturgeon"}}'

-- nads-crow.v2.expected.yaml --
items:
- apiVersion: k8s.cni.cncf.io/v1
  kind: NetworkAttachmentDefinition
  metadata:
    annotations:
      foo: bar
    labels:
      app.kubernetes.io/managed-by: cilium
    name: sturgeon-longhorn
    namespace: crow
    resourceVersion: "<nr>"
  spec:
    config: '{"cniVersion": "0.3.1", "type": "cilium-cni", "enable-debug": false,
      "log-format": "text-ts", "log-file": "/var/run/cilium/cilium-cni.log", "private-networks":
      {"network": "sturgeon", "subnet": "longhorn"}}'
- apiVersion: k8s.cni.cncf.io/v1
  kind: NetworkAttachmentDefinition
  metadata:
    annotations:
      qux: baz
    name: sturgeon-starfish
    namespace: crow
    resourceVersion: "<nr>"
  spec:
    config: '{"cniVersion": "0.3.1", "type": "cilium-cni", "enable-debug": false,
      "log-format": "text-ts","log-file": "/var/run/cilium/cilium-cni.log", "private-networks":
      {"network": "sturgeon"}}'
metadata:
  resourceVersion: "<nr>"
-- EOR --

-- icpn-1.yaml --
apiVersion: isovalent.com/v1alpha1
kind: ClusterwidePrivateNetwork
metadata:
  name: egret
spec:
  subnets:
  - name: select-gull
  - name: parrot
  - name: ewe
  networkAttachmentDefinitions:
    namespaceSelector:
      matchExpressions:
        - key: privnet/egret
          operator: Exists

-- icpn-1.v2.yaml --
apiVersion: isovalent.com/v1alpha1
kind: ClusterwidePrivateNetwork
metadata:
  name: egret
spec:
  subnets:
  - name: select-gull
  - name: opossum
  - name: ewe
  networkAttachmentDefinitions:
    namespaceSelector:
      matchExpressions:
        - key: privnet/egret
          operator: Exists

-- icpn-2.yaml --
apiVersion: isovalent.com/v1alpha1
kind: ClusterwidePrivateNetwork
metadata:
  name: sturgeon
spec:
  subnets:
  - name: starfish
  - name: longhorn
  networkAttachmentDefinitions:
    namespaceSelector:
      matchExpressions:
        - key: privnet/sturgeon
          operator: Exists

-- icpn-2.v2.yaml --
apiVersion: isovalent.com/v1alpha1
kind: ClusterwidePrivateNetwork
metadata:
  name: sturgeon
spec:
  subnets:
  - name: starfish
  - name: longhorn
  networkAttachmentDefinitions:
    namespaceSelector:
      matchLabels:
        kubernetes.io/metadata.name: spaniel

-- icpn-3.yaml --
apiVersion: isovalent.com/v1alpha1
kind: ClusterwidePrivateNetwork
metadata:
  name: egret-select
spec:
  subnets:
  - name: gull

-- icpn-3.v2.yaml --
apiVersion: isovalent.com/v1alpha1
kind: ClusterwidePrivateNetwork
metadata:
  name: egret-select
spec:
  subnets:
  - name: gull
  networkAttachmentDefinitions:
    namespaceSelector:
      matchLabels:
        kubernetes.io/metadata.name: spaniel

-- ns-default.yaml --
apiVersion: v1
kind: Namespace
metadata:
  name: default
  labels:
    kubernetes.io/metadata.name: default
    privnet/egret: ""

-- ns-default.v2.yaml --
apiVersion: v1
kind: Namespace
metadata:
  name: default
  labels:
    kubernetes.io/metadata.name: default

-- ns-spaniel.yaml --
apiVersion: v1
kind: Namespace
metadata:
  name: spaniel
  labels:
    kubernetes.io/metadata.name: spaniel
    privnet/egret: ""
    privnet/sturgeon: ""

-- ns-crow.yaml --
apiVersion: v1
kind: Namespace
metadata:
  name: crow
  labels:
    kubernetes.io/metadata.name: crow
    privnet/sturgeon: ""

-- ns-bluegill.yaml --
apiVersion: v1
kind: Namespace
metadata:
  name: bluegill
  labels:
    kubernetes.io/metadata.name: bluegill
    privnet/egret: ""

