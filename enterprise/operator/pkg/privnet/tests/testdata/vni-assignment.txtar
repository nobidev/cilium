kind: ClusterwidePrivateNetwork
metadata:
  name: test1
  resourceVersion: "<nr>"
spec:
  interface: {}
  routes: null
  subnets:
  - cidr: 10.0.0.0/24
    name: subnet0
  vni: 200
status:
  conditions:
  - lastTransitionTime: "<time>"
    message: Private Network has VNI conflict
    reason: PrivateNetworkHasVNIConflict
    status: "True"
    type: VNIConflict
-- test0-no-request.expected.yaml --
apiVersion: isovalent.com/v1alpha1
kind: ClusterwidePrivateNetwork
metadata:
  name: test0
  resourceVersion: "<nr>"
spec:
  interface: {}
  routes: null
  subnets:
  - cidr: 10.0.0.0/24
    name: subnet0
