#! --private-networks-enabled

# Create the ICPN CRD to satisfy the existence check. We do this before starting
# the hive to prevent unnecessary delay due to retries.
k8s/add icpn-crd.yaml

hive start
db/initialized private-networks

# Add two ClusterwidePrivateNetworks
k8s/add icpn-1.yaml icpn-2.yaml

# Ensure that they are correctly propagated into the table
db/cmp private-networks privnet.v1.table

# Delete one ClusterwidePrivateNetwork, and assert that the deletion is propagated
k8s/delete icpn-1.yaml
db/cmp private-networks privnet.v2.table

# Add it back, and assert that it is present again
k8s/add icpn-1.yaml
db/cmp private-networks privnet.v1.table

-- icpn-crd.yaml --
apiVersion: apiextensions.k8s.io/v1
kind: CustomResourceDefinition
metadata:
  name: clusterwideprivatenetworks.isovalent.com
status:
  conditions:
  - type: "Established"
    status: "True"

-- icpn-1.yaml --
apiVersion: isovalent.com/v1alpha1
kind: ClusterwidePrivateNetwork
metadata:
  name: direct-maggot

-- icpn-2.yaml --
apiVersion: isovalent.com/v1alpha1
kind: ClusterwidePrivateNetwork
metadata:
  name: united-firefly
spec:
  subnets:
  - name: uf-1
  - name: uf-2
  - name: uf-3

-- privnet.v1.table --
Name              Subnets
direct-maggot     0
united-firefly    3

-- privnet.v2.table --
Name              Subnets
united-firefly    3
